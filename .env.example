# Copy to .env and fill in. One file for both Astro and the API — they run in the
# same process. Astro only exposes PUBLIC_* to the browser; everything else stays
# server-side.
#
# In development, SMTP and Turnstile may be left blank: emails and captcha become
# no-ops and leads still save. In production the app REFUSES TO BOOT without them —
# the forms promise "Protected by CAPTCHA" and a confirmation email, and shipping
# without either would make that a lie.

NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:4321

# Number of reverse proxies in front of the app. 0 = none, 1 = behind Cloudflare/nginx.
# Never set this to `true`: X-Forwarded-For becomes spoofable and rate limiting stops
# meaning anything.
TRUST_PROXY=0

# ─── Database ────────────────────────────────────────────────────────────────
# `npm run db:up` starts a local MySQL 8 matching these defaults.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cyberclaims
DB_PASSWORD=cyberclaims
DB_NAME=cyberclaims

# ─── Admin ───────────────────────────────────────────────────────────────────
# Signs the admin session cookie. Min 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Rotating this signs everyone out — that is the intended emergency response.
JWT_SECRET=dev-only-secret-change-me-in-production-at-least-32-chars

# Uploaded media. Relative to the repo root; backed up separately, never committed.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=8

# ─── Email ───────────────────────────────────────────────────────────────────
# Google Workspace (the TBSBV account). Requires an App Password, not the login
# password — Google blocks plain SMTP auth on 2FA accounts.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# The address mail is SENT AS — deliberately separate from SMTP_USER. If
# cyberclaims.net is a domain in the same Workspace, authenticate as the TBSBV
# mailbox but send as Cyberclaims, so a fraud victim gets their confirmation from
# the domain they just visited rather than an unfamiliar one.
# If Workspace rejects the send-as, fall back to the TBSBV address and tell us.
MAIL_FROM=contact@cyberclaims.net
MAIL_FROM_NAME=Cyberclaims

# Where new-lead alerts land.
NOTIFICATION_EMAIL=contact@cyberclaims.net

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# Standalone product — the site does NOT need to sit behind Cloudflare's CDN, only a
# free Cloudflare account for the key pair. https://dash.cloudflare.com → Turnstile.
#
# The values below are Cloudflare's public TEST keys: the widget always passes and
# verification always succeeds. Fine for development, useless as protection.
# REPLACE BOTH BEFORE PRODUCTION.
PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ─── Data retention (GDPR) ───────────────────────────────────────────────────
# Days after a lead is marked `closed` before the row is DELETED. These rows record
# how much money a victim lost and to whom; Article 5(1)(e) says we may not keep them
# longer than the purpose requires. 0 disables the job — be ready to justify that.
LEAD_RETENTION_DAYS=730
