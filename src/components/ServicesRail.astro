---
// Horizontal, snap-scrolling rail of service cards (~4 visible on desktop).
// Used on the service pages ("Explore other services") and About Us ("Explore our services").
import Icon from './Icon.astro';
import { SERVICE_IMAGE } from '../data/services-content';
import { asset, link, serviceUrl } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import { useTranslations, getServices } from '../i18n';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
const t = useTranslations(locale);
const SERVICES = getServices(locale);

interface Props {
  lead: string; // plain part of the heading
  accent: string; // accent-coloured part of the heading
  exclude?: string; // a service href to leave out (e.g. the current page)
}
const { lead, accent, exclude } = Astro.props;
const items = exclude ? SERVICES.filter((s) => s.href !== exclude) : SERVICES;
---

<section class="svc-more">
  <div class="wrap">
    <h2 class="h-section svc-more-h" data-reveal>
      {lead} <span class="accent">{accent}</span>
    </h2>
    <div class="svc-more-grid">
      {
        items.map((s) => (
          <a href={link(serviceUrl(s.href), locale)} class="svc-more-card" data-svc={s.href} data-reveal>
            <img
              class="smc-visual"
              src={asset(SERVICE_IMAGE[s.href])}
              alt=""
              aria-hidden="true"
              loading="lazy"
            />
            <div class="smc-body">
              <h3 class="smc-title">{s.title}</h3>
              <p class="smc-blurb">{s.blurb}</p>
              <span class="smc-more">
                {t('home.servicesExplore')} <Icon name="arrow" class="w-4 h-4" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .svc-more {
    background: var(--color-navy-deep);
    padding: 3.5rem 0 4rem;
  }
  .svc-more-h {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  /* horizontal scroll rail: ~4 visible, X-scroll, edges fade in/out */
  .svc-more-grid {
    display: flex;
    gap: 0.85rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0.6rem 0;
    /* fade widths are toggled per side by JS based on scroll position:
       0 = no fade (nothing more to scroll that way), 3rem = fade hint */
    --fade-l: 0px;
    --fade-r: 3rem;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 var(--fade-l),
      #000 calc(100% - var(--fade-r)),
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 var(--fade-l),
      #000 calc(100% - var(--fade-r)),
      transparent
    );
  }
  .svc-more-grid::-webkit-scrollbar {
    display: none;
  }
  .svc-more-card {
    flex: 0 0 82%;
    scroll-snap-align: start;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 25rem;
    padding: 1.6rem 1.2rem 1.9rem;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    background: linear-gradient(180deg, #1b1630, #0f0f1d);
    border: 1px solid color-mix(in srgb, #8b5bbd 25%, transparent);
    transition: transform 0.35s var(--ease-out-brand), border-color 0.35s,
      box-shadow 0.35s;
  }
  .svc-more-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, #8b5bbd 45%, transparent);
    box-shadow: 0 24px 48px -22px rgba(0, 0, 0, 0.6);
  }
  /* the image sits on the panel and fades into the text (like the homepage
     showcase panels), rather than living in a separate boxed thumbnail */
  .smc-visual {
    position: absolute;
    top: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 104%;
    max-width: 30rem;
    height: auto;
    z-index: 0;
    pointer-events: none;
  }
  /* the maze (tracing) is bright and reads well a touch larger */
  .svc-more-card[data-svc='/cryptocurrency-tracing/'] .smc-visual {
    width: 118%;
    max-width: 34rem;
  }
  /* these three sit low in their frame - lift them up */
  .svc-more-card[data-svc='/cryptocurrency-recovery/'] .smc-visual,
  .svc-more-card[data-svc='/website-forensics/'] .smc-visual,
  .svc-more-card[data-svc='/website-takedown/'] .smc-visual {
    top: -2rem;
  }
  .svc-more-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    /* softer fade so the darker objects don't dissolve into the panel */
    background: linear-gradient(180deg, transparent 26%, #141224 64%, #0f0f1d 100%);
  }
  .smc-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .smc-title {
    font-size: 1.35rem;
    color: #fff;
    margin: 0;
  }
  .smc-blurb {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.5;
  }
  /* solid purple button (matches the homepage showcase panels) */
  .smc-more {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.5rem;
    margin-top: 0.7rem;
    padding: 0.6rem 1.1rem;
    border-radius: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.82rem;
    color: #fff;
    background: var(--color-purple-500);
    box-shadow: 0 8px 24px -8px rgba(107, 63, 160, 0.7);
    transition: background 0.25s var(--ease-out-brand),
      transform 0.25s var(--ease-out-brand);
  }
  .svc-more-card:hover .smc-more {
    background: var(--color-purple-400);
    transform: translateY(-2px);
  }
  @media (min-width: 640px) {
    .svc-more-card {
      flex-basis: 47%;
    }
  }
  @media (min-width: 1024px) {
    .svc-more-card {
      /* four cards visible, the rest reachable by scrolling */
      flex-basis: calc((100% - 3 * 0.85rem) / 4);
    }
  }
</style>

<script>
  // Show the edge fade only on the side that has more cards to scroll into:
  // no left fade at the start, no right fade at the end.
  document.querySelectorAll<HTMLElement>('.svc-more-grid').forEach((rail) => {
    const update = () => {
      const max = rail.scrollWidth - rail.clientWidth;
      rail.style.setProperty('--fade-l', rail.scrollLeft > 4 ? '3rem' : '0px');
      rail.style.setProperty('--fade-r', rail.scrollLeft < max - 4 ? '3rem' : '0px');
    };
    rail.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>
