---
// "Industry Allies / Our Partners" - logo strip with real logos from the live site.
import { PARTNERS } from '../data/site';
import { link } from '../lib/paths';
---

<section class="partners">
  <div class="wrap">
    <div class="partners-head" data-reveal>
      <h2 class="h-section">Industry <span class="accent">allies</span></h2>
      <p class="partners-lead">
        We work alongside leading intelligence providers, law firms and compliance networks
        to give every case the reach it needs.
      </p>
    </div>

    <div class="partners-grid" data-reveal>
      {
        PARTNERS.map((p) => (
          <div class="partner-logo">
            <img src={link(p.src)} alt={p.alt} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .partners {
    padding: 2.5rem 0;
    background: var(--gradient-depth);
  }
  .partners-head {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto 2.75rem;
  }
  .partners-head h2 {
    margin: 0 0 1rem;
  }
  .partners-lead {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 4.5rem;
    padding: 1rem;
    transition: transform 0.3s var(--ease-out-brand);
  }
  .partner-logo:hover {
    transform: translateY(-3px);
  }
  /* white monochrome logos on the dark section */
  .partner-logo img {
    max-width: 100%;
    max-height: 2.4rem;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.55;
    transition: opacity 0.3s var(--ease-out-brand);
  }
  .partner-logo:hover img {
    opacity: 1;
  }
  @media (min-width: 768px) {
    .partners-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .partners-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }
</style>
