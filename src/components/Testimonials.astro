---
// Testimonials - two auto-scrolling marquee rows (pause on hover). Frosted cards.
import { TESTIMONIALS } from '../data/site';

const initials = (n: string) =>
  n.split(' ').map((w) => w[0]).join('').slice(0, 2).toUpperCase();

// Alternate testimonials across the two rows (even -> top, odd -> bottom) so the
// rows show a varied mix rather than two obvious halves.
const rowA = TESTIMONIALS.filter((_, i) => i % 2 === 0);
const rowB = TESTIMONIALS.filter((_, i) => i % 2 === 1);
---

<section class="testi">
  <!-- Ambient background: top glow + concentric arcs + sparkles -->
  <div class="testi-bg" aria-hidden="true">
    <div class="testi-glow"></div>
    <svg class="testi-arcs" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMin slice">
      <g fill="none" stroke="rgba(168,128,209,0.16)" stroke-width="1">
        <circle cx="600" cy="-40" r="220" />
        <circle cx="600" cy="-40" r="360" />
        <circle cx="600" cy="-40" r="500" />
        <circle cx="600" cy="-40" r="650" />
      </g>
    </svg>
    <div class="testi-stars">
      <span class="star" style="top:10%;left:14%;--s:11px;--d:0s"></span>
      <span class="star" style="top:26%;left:32%;--s:8px;--d:1.2s"></span>
      <span class="star" style="top:18%;left:72%;--s:13px;--d:0.6s"></span>
      <span class="star" style="top:38%;left:86%;--s:9px;--d:2s"></span>
      <span class="star" style="top:12%;left:52%;--s:10px;--d:1.6s"></span>
      <span class="star" style="top:52%;left:60%;--s:12px;--d:0.3s"></span>
      <span class="star" style="top:44%;left:8%;--s:9px;--d:2.4s"></span>
      <span class="star" style="top:64%;left:78%;--s:10px;--d:1s"></span>
      <span class="star" style="top:34%;left:46%;--s:8px;--d:0.9s"></span>
      <span class="star" style="top:8%;left:90%;--s:12px;--d:1.8s"></span>
    </div>
  </div>

  <div class="wrap testi-head" data-reveal>
    <h2 class="h-section">Trusted by people we’ve <span class="accent">helped recover</span></h2>
  </div>

  <div class="marquee-mask">
    <div class="marquee">
      <div class="marquee-track">
        {[...rowA, ...rowA].map((t) => (
          <figure class="glass testi-card">
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="avatar">{initials(t.name)}</span>
              <span class="testi-name">{t.name}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
    <div class="marquee">
      <div class="marquee-track reverse">
        {[...rowB, ...rowB].map((t) => (
          <figure class="glass testi-card">
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="avatar">{initials(t.name)}</span>
              <span class="testi-name">{t.name}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testi {
    position: relative;
    padding: 3rem 0;
    background: var(--color-navy);
    overflow: hidden;
  }

  /* ---- ambient background ---- */
  .testi-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  /* glow originating from the TOP of the section, fading downward */
  .testi-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 130%;
    height: 90%;
    background: radial-gradient(
      ellipse 55% 100% at 50% 0%,
      rgba(139, 91, 189, 0.4),
      rgba(107, 63, 160, 0.14) 38%,
      transparent 68%
    );
  }
  .testi-arcs {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 70%;
    opacity: 0.8;
  }
  .testi-stars {
    position: absolute;
    inset: 0;
  }
  /* 4-point sparkle */
  .star {
    position: absolute;
    width: var(--s, 10px);
    height: var(--s, 10px);
    animation: twinkle 3.2s ease-in-out infinite;
    animation-delay: var(--d, 0s);
  }
  .star::before,
  .star::after {
    content: '';
    position: absolute;
    background: rgba(206, 182, 230, 0.85);
    border-radius: 2px;
  }
  .star::before {
    left: 50%;
    top: 0;
    width: 1.5px;
    height: 100%;
    transform: translateX(-50%);
  }
  .star::after {
    top: 50%;
    left: 0;
    height: 1.5px;
    width: 100%;
    transform: translateY(-50%);
  }
  @keyframes twinkle {
    0%,
    100% {
      opacity: 0.2;
      transform: scale(0.7);
    }
    50% {
      opacity: 1;
      transform: scale(1);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .star {
      animation: none;
      opacity: 0.7;
    }
  }

  .testi-head {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 3rem;
  }
  .testi-head h2 {
    margin-top: 0.9rem;
    max-width: 24ch;
    margin-inline: auto;
  }
  .marquee-mask {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .marquee {
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    gap: 1.25rem;
    width: max-content;
    animation: scroll-x 48s linear infinite;
  }
  .marquee-track.reverse {
    animation-direction: reverse;
    animation-duration: 56s;
  }
  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }
  @keyframes scroll-x {
    to {
      transform: translateX(-50%);
    }
  }
  .testi-card {
    flex: 0 0 auto;
    width: 22rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .testi-card blockquote {
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 640px) {
    .testi-card {
      width: 15.5rem;
      padding: 1.1rem;
    }
    .testi-card blockquote {
      font-size: 0.82rem;
      -webkit-line-clamp: 4;
    }
  }
  .testi-card figcaption {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1.2rem;
  }
  .avatar {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    background: var(--gradient-brand);
  }
  .testi-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
    .marquee {
      overflow-x: auto;
    }
  }
</style>
