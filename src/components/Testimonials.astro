---
// Testimonials - two auto-scrolling marquee rows (pause on hover). Frosted cards.
import ArcGlow from './ArcGlow.astro';
import { TESTIMONIALS } from '../data/site';

const initials = (n: string) =>
  n.split(' ').map((w) => w[0]).join('').slice(0, 2).toUpperCase();

// Alternate testimonials across the two rows (even -> top, odd -> bottom) so the
// rows show a varied mix rather than two obvious halves.
const rowA = TESTIMONIALS.filter((_, i) => i % 2 === 0);
const rowB = TESTIMONIALS.filter((_, i) => i % 2 === 1);
---

<section class="testi">
  <!-- Ambient background: top glow + concentric arcs + sparkles -->
  <ArcGlow />

  <div class="wrap testi-head" data-reveal>
    <h2 class="h-section">Trusted by people we’ve <span class="accent">helped recover</span></h2>
  </div>

  <div class="marquee-mask">
    <div class="marquee">
      <div class="marquee-track">
        {[...rowA, ...rowA].map((t) => (
          <figure class="glass testi-card">
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="avatar">{initials(t.name)}</span>
              <span class="testi-name">{t.name}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
    <div class="marquee">
      <div class="marquee-track">
        {[...rowB, ...rowB].map((t) => (
          <figure class="glass testi-card">
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="avatar">{initials(t.name)}</span>
              <span class="testi-name">{t.name}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testi {
    position: relative;
    padding: 3rem 0;
    background: var(--color-navy);
    overflow: hidden;
  }

  .testi-head {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 3rem;
  }
  .testi-head h2 {
    margin-top: 0.9rem;
    max-width: 24ch;
    margin-inline: auto;
  }
  .marquee-mask {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  /* edge fades as overlays (a CSS mask here would create a backdrop root and
     break the cards' backdrop-blur) */
  .marquee-mask::before,
  .marquee-mask::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 8%;
    z-index: 3;
    pointer-events: none;
  }
  .marquee-mask::before {
    left: 0;
    background: linear-gradient(to right, var(--color-navy), transparent);
  }
  .marquee-mask::after {
    right: 0;
    background: linear-gradient(to left, var(--color-navy), transparent);
  }
  .marquee {
    overflow: hidden;
    scrollbar-width: none;
  }
  .marquee::-webkit-scrollbar {
    display: none;
  }
  .marquee-track {
    display: flex;
    gap: 1.25rem;
    width: max-content;
  }
  .testi-card {
    flex: 0 0 auto;
    width: 22rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    /* real frosted glass: translucent + backdrop blur. Works now that the row
       scrolls via JS (no transform) and the edge fade uses overlays (no mask) -
       neither breaks backdrop-filter anymore. */
    background: rgba(30, 30, 52, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .testi-card blockquote {
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 640px) {
    .testi-card {
      width: 15.5rem;
      padding: 1.1rem;
    }
    .testi-card blockquote {
      font-size: 0.82rem;
      -webkit-line-clamp: 4;
    }
  }
  .testi-card figcaption {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1.2rem;
  }
  .avatar {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    background: var(--gradient-brand);
  }
  .testi-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee {
      overflow-x: auto;
    }
  }
</style>

<script>
  // JS-driven marquee (instead of a CSS transform) so the cards' backdrop-blur
  // renders. Two rows scroll in opposite directions; seamless wrap on the
  // duplicated content; pause on hover.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    const rows = document.querySelectorAll<HTMLElement>('.testi .marquee');
    const speeds = [0.4, -0.35];
    rows.forEach((row, i) => {
      const track = row.querySelector<HTMLElement>('.marquee-track');
      if (!track) return;
      const items = track.children;
      const mid = Math.floor(items.length / 2);
      const unit = () => (items[mid] as HTMLElement)?.offsetLeft || 0;
      let pos = speeds[i] < 0 ? unit() : 0;
      let paused = false;
      row.addEventListener('mouseenter', () => (paused = true));
      row.addEventListener('mouseleave', () => (paused = false));
      const step = () => {
        if (!paused) {
          const u = unit();
          if (u > 0) {
            pos += speeds[i];
            if (pos >= u) pos -= u;
            else if (pos < 0) pos += u;
            row.scrollLeft = pos;
          }
        }
        requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });
  }
</script>
