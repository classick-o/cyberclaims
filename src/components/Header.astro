---
// Sticky header: transparent → dark on scroll (brief §4 Nav). Mega-menu for services.
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { SERVICES, URL_CHECKER } from '../data/site';
import { link, serviceUrl } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
---

<header id="site-header" class="site-header" data-at-top="true">
  <div class="wrap header-inner">
    <Logo />

    <nav class="nav-desktop" aria-label="Primary">
      <a href={link('/', locale)} class="nav-link">Home</a>
      <a href={link('/about-us/', locale)} class="nav-link">About Us</a>

      <div class="nav-has-mega">
        <a href={link('/services/', locale)} class="nav-link nav-trigger" aria-haspopup="true">
          Our Services
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m6 9 6 6 6-6" /></svg>
        </a>

        <div class="mega" role="menu">
          <div class="mega-grid">
            {
              SERVICES.map((s) => (
                <a href={link(serviceUrl(s.href), locale)} class="mega-item" role="menuitem">
                  <span class="mega-icon">
                    <Icon name={s.icon} class="w-4 h-4" />
                  </span>
                  <span class="mega-text">
                    <span class="mega-title">{s.title}</span>
                    <span class="mega-blurb">{s.short}</span>
                  </span>
                </a>
              ))
            }
          </div>
          <a href={link(URL_CHECKER.href, locale)} class="mega-foot">
            <Icon name={URL_CHECKER.icon} class="w-4 h-4" /> {URL_CHECKER.title} - verify a suspicious
            link
          </a>
        </div>
      </div>

      <a href={link('/news/', locale)} class="nav-link">News</a>
      <a href={link('/contact-us/', locale)} class="nav-link">Contact Us</a>
    </nav>

    <a href={link('/start-process/', locale)} class="btn btn-header">Start Process</a>

    <button id="burger" class="burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-drawer" class="mobile-drawer">
    <nav class="mobile-nav" aria-label="Mobile">
      <a href={link('/', locale)}>Home</a>
      <a href={link('/about-us/', locale)}>About Us</a>
      <details class="mobile-details">
        <summary>
          <span>Our Services</span>
          <svg
            class="mobile-chevron"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </summary>
        <div class="mobile-services">
          {SERVICES.map((s) => <a href={link(serviceUrl(s.href), locale)}>{s.title}</a>)}
          <a href={link(URL_CHECKER.href, locale)}>{URL_CHECKER.title}</a>
        </div>
      </details>
      <a href={link('/news/', locale)}>News</a>
      <a href={link('/contact-us/', locale)}>Contact Us</a>
      <a href={link('/start-process/', locale)} class="btn mobile-cta">Start Process</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 60;
  }
  /* Blurred bar background lives on a pseudo-element (NOT an ancestor of the
     mega-menu), so it doesn't create a nested backdrop root that would break
     the mega's own backdrop-filter. Both blurs now coexist. */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0;
    background: rgba(15, 15, 28, 0.7);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    backdrop-filter: blur(14px) saturate(140%);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: opacity 0.4s var(--ease-out-brand);
  }
  .site-header[data-at-top='false']::before {
    opacity: 1;
  }
  /* when the mobile menu is open, show the blurred bar even at the top */
  .site-header:has(#mobile-drawer.open)::before {
    opacity: 1;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4.75rem;
  }
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.85rem;
    font-size: 0.92rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.82);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
  }
  /* underline slide-in from left (brief §5) */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.3rem;
    height: 1.5px;
    background: var(--color-purple-300);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out-brand);
  }
  .nav-link:hover {
    color: #fff;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-has-mega {
    position: static;
  }
  .mega {
    position: absolute;
    left: 0;
    right: 0;
    margin-inline: auto;
    top: calc(100% + 0.9rem); /* hidden: slightly lower */
    width: min(42rem, calc(100vw - 3rem));
    padding: 0.85rem;
    background: rgba(18, 18, 32, 0.55);
    /* NOTE: no `transform` here - it would disable backdrop-filter in Chromium */
    -webkit-backdrop-filter: blur(32px) saturate(150%);
    backdrop-filter: blur(32px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.7rem;
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.7);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.28s var(--ease-out-brand),
      top 0.28s var(--ease-out-brand), visibility 0.28s;
  }
  .nav-has-mega:hover .mega,
  .nav-has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    top: calc(100% + 0.3rem); /* visible: settle up */
  }
  .mega-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.2rem;
  }
  .mega-item {
    display: flex;
    gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.6rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .mega-item:hover {
    background: rgba(139, 91, 189, 0.12);
  }
  .mega-icon {
    flex-shrink: 0;
    width: 1.85rem;
    height: 1.85rem;
    display: grid;
    place-items: center;
    border-radius: 0.5rem;
    color: var(--color-purple-300);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .mega-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .mega-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
  }
  .mega-blurb {
    font-size: 0.7rem;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.55);
  }
  .mega-foot {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.55rem;
    padding: 0.55rem 0.7rem;
    border-radius: 0.6rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-purple-200);
    background: rgba(139, 91, 189, 0.1);
    text-decoration: none;
  }
  .mega-foot:hover {
    background: rgba(139, 91, 189, 0.18);
  }
  .mega-foot :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  .btn-header {
    display: none;
    padding: 0.7rem 1.4rem;
    font-size: 0.88rem;
  }

  .burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.6rem;
    height: 2.6rem;
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 22px;
    margin-inline: auto;
    background: #fff;
    transition: transform 0.3s, opacity 0.3s;
  }
  .burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-drawer {
    overflow: hidden;
    max-height: 0;
    /* translucent so the backdrop blur is actually visible behind the menu */
    background: rgba(16, 16, 32, 0.6);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
    transition: max-height 0.4s var(--ease-out-brand);
  }
  .mobile-drawer.open {
    max-height: 90vh;
    /* the page can't scroll while the menu is open, so let the menu itself
       scroll if its links overflow a short viewport */
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 2rem;
    gap: 0.25rem;
  }
  .mobile-nav > a,
  .mobile-nav summary {
    padding: 0.85rem 0.25rem;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 1.05rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
  }
  /* drop the native disclosure triangle (both the modern and the WebKit marker) */
  .mobile-nav summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    list-style: none;
  }
  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }
  .mobile-chevron {
    flex-shrink: 0;
    color: var(--color-purple-300);
    transition: transform 0.3s var(--ease-out-brand);
  }
  .mobile-details[open] .mobile-chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-chevron {
      transition: none;
    }
  }
  .mobile-services {
    display: flex;
    flex-direction: column;
    padding: 0.25rem 0 0.5rem 0.9rem;
  }
  .mobile-services a {
    padding: 0.6rem 0;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }
  .mobile-cta {
    margin-top: 1rem;
    justify-content: center;
  }

  /* ---- page state while the mobile drawer is open ---- */
  /* Freeze the page behind the menu. This must sit on <html>, not <body>: global
     css sets `html { overflow-x: hidden }`, so the viewport's scrollport is the
     root element and body's overflow no longer propagates up to it. */
  :global(html.nav-open) {
    overflow: hidden;
  }
  /* Blur + disable everything except the header itself. Targeting body's other
     children (main, the notice band, the footer) rather than a wrapper keeps the
     header - and the drawer inside it - perfectly sharp. */
  :global(body > *:not(#site-header)) {
    transition: filter 0.35s var(--ease-out-brand);
  }
  :global(body.nav-open > *:not(#site-header)) {
    filter: blur(6px);
    pointer-events: none;
    user-select: none;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(body > *:not(#site-header)) {
      transition: none;
    }
  }

  @media (min-width: 1024px) {
    /* 3-column grid: logo left, nav centered, CTA right (no transform, so the
       mega-menu's backdrop-filter keeps working) */
    .header-inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
    }
    .header-inner > :first-child {
      justify-self: start;
    }
    .nav-desktop {
      display: flex;
    }
    .btn-header {
      display: inline-flex;
      justify-self: end;
    }
    .burger {
      display: none;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const onScroll = () =>
    header.setAttribute('data-at-top', String(window.scrollY < 24));
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.getElementById('burger')!;
  const drawer = document.getElementById('mobile-drawer')!;

  // `nav-open` blurs the page (on <body>) and freezes its scroll (on <html>)
  const setOpen = (open: boolean) => {
    drawer.classList.toggle('open', open);
    document.body.classList.toggle('nav-open', open);
    document.documentElement.classList.toggle('nav-open', open);
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  };

  burger.addEventListener('click', () => setOpen(!drawer.classList.contains('open')));
  drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) setOpen(false);
  });
</script>
