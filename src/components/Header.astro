---
// Sticky header: transparent → dark on scroll (brief §4 Nav). Mega-menu for services.
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { SERVICES, URL_CHECKER } from '../data/site';
import { link } from '../lib/paths';
---

<header id="site-header" class="site-header" data-at-top="true">
  <div class="wrap header-inner">
    <Logo />

    <nav class="nav-desktop" aria-label="Primary">
      <a href={link('/')} class="nav-link">Home</a>
      <a href={link('/about-us/')} class="nav-link">About Us</a>

      <div class="nav-has-mega">
        <button class="nav-link nav-trigger" aria-expanded="false" aria-haspopup="true">
          Our Services
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m6 9 6 6 6-6" /></svg>
        </button>

        <div class="mega" role="menu">
          <div class="mega-grid">
            {
              SERVICES.map((s) => (
                <a href={link(s.href)} class="mega-item" role="menuitem">
                  <span class="mega-icon">
                    <Icon name={s.icon} class="w-4 h-4" />
                  </span>
                  <span class="mega-text">
                    <span class="mega-title">{s.title}</span>
                    <span class="mega-blurb">{s.short}</span>
                  </span>
                </a>
              ))
            }
          </div>
          <a href={link(URL_CHECKER.href)} class="mega-foot">
            <Icon name="url" class="w-4 h-4" /> {URL_CHECKER.title} - verify a suspicious link
          </a>
        </div>
      </div>

      <a href={link('/news/')} class="nav-link">News</a>
      <a href={link('/contact-us/')} class="nav-link">Contact Us</a>
    </nav>

    <a href={link('/start-process/')} class="btn btn-header">Start Process</a>

    <button id="burger" class="burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-drawer" class="mobile-drawer">
    <nav class="mobile-nav" aria-label="Mobile">
      <a href={link('/')}>Home</a>
      <a href={link('/about-us/')}>About Us</a>
      <details>
        <summary>Our Services</summary>
        <div class="mobile-services">
          {SERVICES.map((s) => <a href={link(s.href)}>{s.title}</a>)}
          <a href={link(URL_CHECKER.href)}>{URL_CHECKER.title}</a>
        </div>
      </details>
      <a href={link('/news/')}>News</a>
      <a href={link('/contact-us/')}>Contact Us</a>
      <a href={link('/start-process/')} class="btn mobile-cta">Start Process</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 60;
  }
  /* Blurred bar background lives on a pseudo-element (NOT an ancestor of the
     mega-menu), so it doesn't create a nested backdrop root that would break
     the mega's own backdrop-filter. Both blurs now coexist. */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0;
    background: rgba(15, 15, 28, 0.7);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: opacity 0.4s var(--ease-out-brand);
  }
  .site-header[data-at-top='false']::before {
    opacity: 1;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4.75rem;
  }
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    margin-right: 1.25rem;
  }
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.85rem;
    font-size: 0.92rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.82);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
  }
  /* underline slide-in from left (brief §5) */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.3rem;
    height: 1.5px;
    background: var(--color-purple-300);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out-brand);
  }
  .nav-link:hover {
    color: #fff;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-has-mega {
    position: static;
  }
  .mega {
    position: absolute;
    left: 0;
    right: 0;
    margin-inline: auto;
    top: calc(100% + 0.9rem); /* hidden: slightly lower */
    width: min(42rem, calc(100vw - 3rem));
    padding: 0.85rem;
    background: rgba(18, 18, 32, 0.55);
    /* NOTE: no `transform` here - it would disable backdrop-filter in Chromium */
    backdrop-filter: blur(32px) saturate(150%);
    -webkit-backdrop-filter: blur(32px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.7rem;
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.7);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.28s var(--ease-out-brand),
      top 0.28s var(--ease-out-brand), visibility 0.28s;
  }
  .nav-has-mega:hover .mega,
  .nav-has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    top: calc(100% + 0.3rem); /* visible: settle up */
  }
  .mega-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.2rem;
  }
  .mega-item {
    display: flex;
    gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.6rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .mega-item:hover {
    background: rgba(139, 91, 189, 0.12);
  }
  .mega-icon {
    flex-shrink: 0;
    width: 1.85rem;
    height: 1.85rem;
    display: grid;
    place-items: center;
    border-radius: 0.5rem;
    color: var(--color-purple-300);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .mega-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .mega-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
  }
  .mega-blurb {
    font-size: 0.7rem;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.55);
  }
  .mega-foot {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.55rem;
    padding: 0.55rem 0.7rem;
    border-radius: 0.6rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-purple-200);
    background: rgba(139, 91, 189, 0.1);
    text-decoration: none;
  }
  .mega-foot:hover {
    background: rgba(139, 91, 189, 0.18);
  }
  .mega-foot :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  .btn-header {
    display: none;
    padding: 0.7rem 1.4rem;
    font-size: 0.88rem;
  }

  .burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.6rem;
    height: 2.6rem;
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 22px;
    margin-inline: auto;
    background: #fff;
    transition: transform 0.3s, opacity 0.3s;
  }
  .burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-drawer {
    overflow: hidden;
    max-height: 0;
    background: rgba(16, 16, 32, 0.98);
    backdrop-filter: blur(14px);
    transition: max-height 0.4s var(--ease-out-brand);
  }
  .mobile-drawer.open {
    max-height: 90vh;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 2rem;
    gap: 0.25rem;
  }
  .mobile-nav > a,
  .mobile-nav summary {
    padding: 0.85rem 0.25rem;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 1.05rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
  }
  .mobile-services {
    display: flex;
    flex-direction: column;
    padding: 0.25rem 0 0.5rem 0.9rem;
  }
  .mobile-services a {
    padding: 0.6rem 0;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }
  .mobile-cta {
    margin-top: 1rem;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .nav-desktop {
      display: flex;
    }
    .btn-header {
      display: inline-flex;
    }
    .burger {
      display: none;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const onScroll = () =>
    header.setAttribute('data-at-top', String(window.scrollY < 24));
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.getElementById('burger')!;
  const drawer = document.getElementById('mobile-drawer')!;
  burger.addEventListener('click', () => {
    const open = drawer.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
  });
  drawer.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      drawer.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
    })
  );
</script>
