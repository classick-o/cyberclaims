---
// 4-column footer + trust badges (brief §4 Footer).
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { CONTACT } from '../data/site';
import { asset, link, serviceUrl } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import { useTranslations, getServices } from '../i18n';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
const t = useTranslations(locale);

const quickLinks = [
  { label: t('nav.about'), href: '/about-us/' },
  { label: t('nav.news'), href: '/news/' },
  { label: t('nav.startProcess'), href: '/start-process/' },
  { label: t('nav.contact'), href: '/contact-us/' },
];
const resources = [
  { label: t('legal.cookieTitle'), href: '/cookie-policy/' },
  { label: t('legal.privacyTitle'), href: '/privacy-policy/' },
  { label: t('legal.termsTitle'), href: '/terms-and-conditions/' },
  { label: t('legal.dpaTitle'), href: '/data-protection-addendum/' },
];
// map a phone region to its ISO flag file (UK uses the GB flag)
const flagOf = (region: string): string => (region === 'UK' ? 'GB' : region);
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <!-- Company -->
      <div class="footer-col footer-brand">
        <Logo />
        <p class="footer-tag">{t('footer.tag')}</p>
        <div class="badges">
          <span class="badge"><Icon name="shield" class="w-4 h-4" /> {t('trust.moj', { pob: CONTACT.pob })}</span>
          <span class="badge"><Icon name="check" class="w-4 h-4" /> {t('footer.badgeRegistered')}</span>
          <span class="badge"><Icon name="lock" class="w-4 h-4" /> {t('footer.badgeGdpr')}</span>
        </div>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-h">{t('nav.services')}</h4>
        <ul>
          {getServices(locale).slice(0, 8).map((s) => <li><a href={link(serviceUrl(s.href), locale)}>{s.title}</a></li>)}
        </ul>
      </div>

      <!-- Quick links + Resources -->
      <div class="footer-col">
        <h4 class="footer-h">{t('footer.colCompany')}</h4>
        <ul>
          {quickLinks.map((l) => <li><a href={link(l.href, locale)}>{l.label}</a></li>)}
        </ul>
        <h4 class="footer-h footer-h-sub">{t('footer.colResources')}</h4>
        <ul>
          {resources.map((l) => <li><a href={link(l.href, locale)}>{l.label}</a></li>)}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 class="footer-h">{t('footer.colContact')}</h4>
        <ul class="contact-list">
          {CONTACT.phones.map((p) => (
            <li>
              <img
                class="ct-flag"
                src={asset(`/flags/${flagOf(p.region)}.svg`)}
                alt={p.region}
                width="22"
                height="22"
                loading="lazy"
              />
              <a href={`tel:${p.number.replace(/\s/g, '')}`}>{p.number}</a>
            </li>
          ))}
        </ul>
        <a class="contact-email" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        <p class="contact-addr">{t('contact.address')}</p>
      </div>
    </div>

    <p class="legal">{t('footer.legal', { pob: CONTACT.pob })}</p>

    <div class="footer-bottom">
      <span>{t('footer.copyright', { year: new Date().getFullYear() })}</span>
      <span class="footer-bottom-links">
        <a href={link('/privacy-policy/', locale)}>{t('legal.privacyTitle')}</a>
        <a href={link('/cookie-policy/', locale)}>{t('legal.cookieTitle')}</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--color-navy-deep);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    padding: 4.5rem 0 2rem;
    margin-top: 2rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.75rem;
  }
  .footer-tag {
    margin: 1.1rem 0 1.4rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 20rem;
  }
  .badges {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: flex-start;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    background: rgba(139, 91, 189, 0.1);
    border: 1px solid rgba(139, 91, 189, 0.25);
  }
  .badge :global(svg) {
    width: 1rem;
    height: 1rem;
    color: var(--color-purple-300);
  }
  .footer-h {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-300);
    margin-bottom: 1rem;
  }
  .footer-h-sub {
    margin-top: 1.6rem;
  }
  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-col a {
    color: rgba(255, 255, 255, 0.62);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .contact-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.55rem;
  }
  .ct-flag {
    width: 1.4rem;
    height: 1.4rem;
    flex-shrink: 0;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.14);
  }
  .contact-email {
    display: inline-block;
    margin: 0.6rem 0;
    color: #fff !important;
    font-weight: 500;
  }
  .contact-addr {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
    max-width: 16rem;
  }
  .socials {
    display: flex;
    gap: 0.6rem;
    margin-top: 1rem;
  }
  .socials a {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    color: #fff !important;
    font-size: 0.85rem;
  }
  .socials a:hover {
    background: var(--color-purple-500);
  }
  .legal {
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.4);
  }
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
  }
  .footer-bottom-links {
    display: flex;
    gap: 1.25rem;
  }
  .footer-bottom-links a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    }
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
