---
// Services - interactive showcase: a list on the left drives a preview panel on
// the right (hover / keyboard-focus to switch). Collapses to tappable cards on mobile.
import Icon from './Icon.astro';
import { SERVICES } from '../data/site';
import { link, serviceUrl } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);

// per-service preview visual (falls back to the default tiles image)
const VISUALS: Record<string, string> = {
  '/brand-protection/': '/sv-brand-protection.webp',
  '/consultancy-documentation-support/': '/sv-consultancy.webp',
  '/website-forensics/': '/sv-website-forensics.webp',
  '/website-takedown/': '/sv-website-takedown.webp',
  '/cryptocurrency-tracing/': '/sv-crypto-tracing.webp',
  '/dispute-resolution-support/': '/sv-dispute.webp',
  '/due-diligence-investigations/': '/sv-social-media.webp',
  '/social-media-investigation/': '/sv-due-diligence.webp',
  '/business-services/': '/sv-business.webp',
};
const visualOf = (href: string): string => VISUALS[href] ?? '/service-visual.webp';
---

<section class="services">
  <div class="wrap services-head" data-reveal>
    <h2 class="h-section">What we <span class="accent">investigate</span></h2>
  </div>

  <div class="wrap showcase">
    <!-- Left: list -->
    <ul class="sc-list">
      {
        SERVICES.map((s, i) => (
          <li>
            <a
              href={link(serviceUrl(s.href), locale)}
              class={`sc-item${i === 0 ? ' is-active' : ''}`}
              style={`--accent:${s.accent}`}
            >
              <span class="sc-item-icon"><Icon name={s.icon} class="w-4 h-4" /></span>
              <span class="sc-item-text">
                <span class="sc-item-title">{s.title}</span>
                <span class="sc-item-blurb">{s.short}</span>
              </span>
              <span class="sc-item-arrow"><Icon name="arrow" class="w-full h-full" /></span>
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Right: preview (desktop/tablet) -->
    <div class="sc-preview">
      {
        SERVICES.map((s, i) => (
          <div
            class={`sc-panel${i === 0 ? ' is-active' : ''}`}
            style={`--accent:${s.accent}`}
            data-svc={s.href}
          >
            <img
              class="sc-visual"
              src={link(visualOf(s.href), locale)}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
            />
            <div class="sc-panel-body">
              <h3 class="sc-panel-title">{s.title}</h3>
              <p class="sc-panel-blurb">{s.blurb}</p>
              <a href={link(serviceUrl(s.href), locale)} class="sc-more">Explore service <Icon name="arrow" class="w-4 h-4" /></a>
            </div>
          </div>
        ))
      }
    </div>

    <!-- carousel progress dots (mobile / tablet only) -->
    <div class="sc-dots">
      {
        SERVICES.map((s, i) => (
          <button
            type="button"
            class={`sc-dot${i === 0 ? ' is-active' : ''}`}
            data-dot={i}
            aria-label={s.title}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  .services-head {
    margin-bottom: 2.5rem;
  }
  .showcase {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* ---- list ---- */
  .sc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .sc-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: 0.7rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.72);
    border: 1px solid transparent;
    transition: background 0.25s var(--ease-out-brand), color 0.25s,
      border-color 0.25s;
  }
  .sc-item:hover,
  .sc-item.is-active {
    background: rgba(139, 91, 189, 0.1);
    border-color: rgba(139, 91, 189, 0.3);
    color: #fff;
  }
  .sc-item-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.55rem;
    /* solid purple chip; icon inherits the item's text color (white on hover) */
    color: inherit;
    background: var(--color-purple-500);
    border: 1px solid transparent;
    transition: color 0.25s;
  }
  .sc-item-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .sc-item-title {
    font-size: 0.95rem;
    font-weight: 500;
    font-family: var(--font-display);
  }
  .sc-item-blurb {
    display: none;
    font-size: 0.8rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.15rem;
  }
  .sc-item-arrow {
    display: block;
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-purple-300);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s, transform 0.25s var(--ease-out-brand);
  }
  .sc-item:hover .sc-item-arrow,
  .sc-item.is-active .sc-item-arrow {
    opacity: 1;
    transform: none;
  }

  /* ---- preview ---- */
  .sc-preview {
    position: relative;
    min-height: 24rem;
    border-radius: 1rem;
  }
  .sc-panel {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem 2rem 3.5rem;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    opacity: 0;
    visibility: hidden;
    transform: scale(1.015);
    transition: opacity 0.4s var(--ease-out-brand),
      transform 0.5s var(--ease-out-brand), visibility 0.4s;
    background: linear-gradient(180deg, #1b1630, #0f0f1d);
    border: 1px solid color-mix(in srgb, #8b5bbd 30%, transparent);
  }
  .sc-panel.is-active {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  /* service visual, centered on the X axis in the top area, faded toward the text */
  .sc-visual {
    position: absolute;
    top: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 96%;
    max-width: 36rem;
    height: auto;
    pointer-events: none;
    z-index: 0;
  }
  /* panel-fixed fade: guarantees the image fades out at the SAME vertical point
     on every card, regardless of each image's own size/top offset */
  .sc-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 12%, #141224 58%, #0f0f1d 100%);
  }
  /* per-service visual position tweaks */
  .sc-panel[data-svc='/brand-protection/'] .sc-visual {
    top: -5rem;
  }
  .sc-panel[data-svc='/website-forensics/'] .sc-visual {
    top: -7rem;
    width: 108%;
    max-width: 42rem;
  }
  .sc-panel[data-svc='/website-takedown/'] .sc-visual {
    top: -7rem;
    width: 108%;
    max-width: 42rem;
  }
  .sc-panel[data-svc='/cryptocurrency-tracing/'] .sc-visual {
    top: 0rem;
    width: 138%;
    max-width: 52rem;
  }
  .sc-panel[data-svc='/dispute-resolution-support/'] .sc-visual {
    top: -1.5rem;
    width: 136%;
    max-width: 52rem;
  }
  .sc-panel[data-svc='/due-diligence-investigations/'] .sc-visual,
  .sc-panel[data-svc='/social-media-investigation/'] .sc-visual,
  .sc-panel[data-svc='/business-services/'] .sc-visual {
    top: -1.5rem;
    width: 144%;
    max-width: 52rem;
  }
  .sc-panel-body {
    position: relative;
    z-index: 2;
  }
  .sc-panel-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.7rem;
  }
  .sc-panel-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.7rem;
    color: #fff;
    background: color-mix(in srgb, #8b5bbd 55%, transparent);
    border: 1px solid color-mix(in srgb, #8b5bbd 60%, transparent);
  }
  .sc-panel-title {
    font-size: 1.95rem;
    color: #fff;
    margin: 0 0 0.7rem;
  }
  .sc-panel-blurb {
    font-size: 1.02rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 44ch;
    margin-bottom: 1.4rem;
  }
  .sc-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    align-self: flex-start;
    padding: 0.6rem 1.1rem;
    border-radius: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    color: #fff;
    background: var(--color-purple-500);
    border: 1px solid transparent;
    box-shadow: 0 8px 24px -8px rgba(107, 63, 160, 0.7);
    transition: background 0.25s var(--ease-out-brand),
      transform 0.25s var(--ease-out-brand),
      box-shadow 0.25s var(--ease-out-brand);
  }
  .sc-more:hover {
    background: var(--color-purple-400);
    transform: translateY(-2px);
    box-shadow: 0 14px 34px -8px rgba(139, 91, 189, 0.85);
  }

  /* ---- desktop split ---- */
  @media (min-width: 900px) {
    .showcase {
      grid-template-columns: 0.82fr 1.18fr;
      gap: 1.5rem;
      align-items: stretch;
      /* unified frosted-glass panel behind the list + preview */
      padding: 1rem;
      border-radius: 1.25rem;
      background: linear-gradient(160deg, rgba(35, 35, 64, 0.42), rgba(20, 20, 38, 0.38));
      backdrop-filter: blur(20px) saturate(140%);
      -webkit-backdrop-filter: blur(20px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.07);
    }
    /* let the preview bleed out of the panel so it reads as a layer emerging
       from underneath it (extends top/bottom/right, lifted with a shadow) */
    .sc-preview {
      min-height: 26rem;
      position: relative;
      z-index: 2;
      margin: -2rem -2rem -2rem 0;
    }
    .sc-panel {
      box-shadow: 0 34px 70px -34px rgba(0, 0, 0, 0.75);
    }
  }

  /* ---- carousel progress dots (hidden on desktop) ---- */
  .sc-dots {
    display: none;
  }
  .sc-dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    cursor: pointer;
    transition: background 0.3s var(--ease-out-brand),
      width 0.3s var(--ease-out-brand);
  }
  .sc-dot.is-active {
    width: 1.5rem;
    background: var(--color-purple-400);
  }

  /* ---- mobile / tablet: list hidden, preview becomes a swipe carousel ---- */
  @media (max-width: 899px) {
    .sc-list {
      display: none;
    }
    .showcase {
      gap: 1rem;
    }
    .sc-preview {
      display: flex;
      min-height: 0;
      gap: 0.85rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .sc-preview::-webkit-scrollbar {
      display: none;
    }
    .sc-panel {
      position: relative;
      inset: auto;
      flex: 0 0 100%;
      min-height: 30rem;
      scroll-snap-align: center;
      /* carousel slides are all shown; scroll (not hover) drives the view */
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: 0 24px 50px -30px rgba(0, 0, 0, 0.8);
      /* tighter side padding + smaller bottom so text/button sit lower */
      padding: 1.5rem 1.25rem 2rem;
    }
    /* smaller type on mobile */
    .sc-panel-title {
      font-size: 1.6rem;
    }
    .sc-panel-blurb {
      font-size: 0.9rem;
      margin-bottom: 1.1rem;
    }
    /* push these visuals lower on mobile only */
    .sc-panel[data-svc='/brand-protection/'] .sc-visual {
      top: -2rem;
    }
    .sc-panel[data-svc='/website-forensics/'] .sc-visual {
      top: -3.5rem;
    }
    .sc-panel[data-svc='/website-takedown/'] .sc-visual {
      top: -3.5rem;
    }
    .sc-dots {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
    }
  }
</style>

<script>
  // Hover / focus on a list item drives the preview panel (desktop & tablet).
  const items = Array.from(document.querySelectorAll<HTMLElement>('.sc-item'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.sc-panel'));
  const activate = (i: number) => {
    items.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
    panels.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
  };
  items.forEach((el, i) => {
    el.addEventListener('mouseenter', () => activate(i));
    el.addEventListener('focus', () => activate(i));
  });

  // Mobile / tablet carousel: sync progress dots with scroll position, and
  // let a dot tap scroll its panel into view. (On desktop the preview never
  // scrolls, so these listeners stay dormant.)
  const preview = document.querySelector<HTMLElement>('.sc-preview');
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.sc-dot'));
  if (preview && dots.length) {
    const setActiveDot = () => {
      const center = preview.scrollLeft + preview.clientWidth / 2;
      let best = 0,
        bestDist = Infinity;
      panels.forEach((p, i) => {
        const c = p.offsetLeft + p.offsetWidth / 2;
        const dist = Math.abs(c - center);
        if (dist < bestDist) {
          bestDist = dist;
          best = i;
        }
      });
      dots.forEach((d, i) => d.classList.toggle('is-active', i === best));
    };
    preview.addEventListener('scroll', setActiveDot, { passive: true });
    dots.forEach((d, i) => {
      d.addEventListener('click', () => {
        const p = panels[i];
        preview.scrollTo({
          left: p.offsetLeft - (preview.clientWidth - p.offsetWidth) / 2,
          behavior: 'smooth',
        });
      });
    });
  }
</script>
