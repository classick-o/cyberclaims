---
// Section background: a purple spotlight glowing from the top-centre with soft
// vertical light streaks (god-rays). Sits at the top of its position:relative
// parent and fades into the section background below (runs behind the text).
//
// The height is the gradient's own coordinate space, so it must stay large for
// the glow to keep its reach - a short section should clip it and fade the seam
// (see `.has-aurora::after`), not shrink the box.
---

<div class="aurora" aria-hidden="true">
  <div class="aurora-rays"></div>
</div>

<style>
  .aurora {
    position: absolute;
    inset: 0 0 auto 0;
    height: 90rem;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* purple spotlight glowing from the top centre (kept top-concentrated) */
    background: radial-gradient(
      130% 70% at 50% -4%,
      rgba(139, 91, 189, 0.5),
      rgba(107, 63, 160, 0.2) 32%,
      rgba(29, 17, 48, 0) 60%
    );
    /* long, gradual fade into the section background - runs far down behind text */
    -webkit-mask-image: linear-gradient(to bottom, #000 20%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 20%, transparent 100%);
  }
  /* soft vertical light streaks, concentrated near the top-centre */
  .aurora-rays {
    position: absolute;
    inset: -10% 0 0;
    background: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 3.4rem,
      rgba(168, 128, 209, 0.055) 3.9rem,
      transparent 4.4rem
    );
    -webkit-mask-image: radial-gradient(65% 85% at 50% 0%, #000, transparent 72%);
    mask-image: radial-gradient(65% 85% at 50% 0%, #000, transparent 72%);
    animation: rays-drift 26s ease-in-out infinite;
  }
  @keyframes rays-drift {
    50% {
      transform: translateX(1.6rem);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .aurora-rays {
      animation: none;
    }
  }
  @media (max-width: 640px) {
    .aurora {
      height: 62rem;
    }
  }
</style>
