---
// Press / media coverage - "As seen on 350+ news sites" logo marquee + featured story.
import { PRESS } from '../data/site';
import { localeFromUrl } from '../i18n/config';
import { useTranslations } from '../i18n';

const t = useTranslations(localeFromUrl(Astro.url));
---

<section class="press">
  <div class="wrap press-head" data-reveal>
    <span class="press-badge">{t('home.pressBadge')}</span>
    <h2
      class="press-story"
      set:html={t('home.pressStory', { accent: `<span class="accent">${t('home.pressStoryA')}</span>` })}
    />
  </div>

  <div class="press-marquee-mask">
    <div class="press-track">
      {[...PRESS, ...PRESS].map((p) => (
        <a class="press-logo" href={p.url} target="_blank" rel="noopener noreferrer">{p.name}</a>
      ))}
    </div>
  </div>

  <p class="press-verify wrap" data-reveal>{t('home.pressVerified')}</p>
</section>

<style>
  .press {
    padding: 2.5rem 0;
    background: var(--color-navy-deep);
    overflow: hidden;
  }
  .press-head {
    text-align: center;
    margin-bottom: 2.75rem;
  }
  .press-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-purple-300);
    margin-bottom: 1rem;
  }
  .press-story {
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.3;
    max-width: 26ch;
    margin-inline: auto;
    color: rgba(255, 255, 255, 0.92);
  }
  .press-marquee-mask {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
  }
  .press-track {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: max-content;
    animation: scroll-x 40s linear infinite;
  }
  @keyframes scroll-x {
    to {
      transform: translateX(-50%);
    }
  }
  .press-logo {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.3s;
    text-decoration: none;
  }
  .press-logo:hover {
    color: #fff;
  }
  /* pause the marquee on hover so the links are easy to click */
  .press-track:hover {
    animation-play-state: paused;
  }
  .press-verify {
    text-align: center;
    margin-top: 2rem;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
  }
  @media (prefers-reduced-motion: reduce) {
    .press-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
