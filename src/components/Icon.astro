---
// Line-style forensic/tech icons. Stroke = currentColor so we can tint per service accent.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = '' } = Astro.props;

const paths: Record<string, string> = {
  recovery:
    '<path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v4h4"/><path d="M12 8v4l3 2"/>',
  tracing:
    '<circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><circle cx="17" cy="6" r="1.5"/><path d="M8 7.5 15 17M8 6h7M8 7l7 9"/>',
  forensics:
    '<circle cx="11" cy="11" r="6"/><path d="m20 20-4.3-4.3"/><path d="M11 8v6M8 11h6"/>',
  shield:
    '<path d="M12 3 5 6v5c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>',
  takedown:
    '<rect x="4" y="6" width="16" height="12" rx="2"/><path d="M4 10h16"/><path d="m9 14 6 0M12 14v0"/><path d="m8 3 8 3"/>',
  dispute:
    '<path d="M12 3v18"/><path d="M6 8 3 14h6L6 8ZM18 8l-3 6h6l-3-6Z"/><path d="M4 21h16M8 5h8"/>',
  consultancy:
    '<path d="M4 5h16v11H4z"/><path d="M8 20h8M12 16v4"/><path d="M8 9h8M8 12h5"/>',
  diligence:
    '<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9Z"/><path d="M14 3v6h6"/><path d="m9 14 2 2 4-4"/>',
  social:
    '<circle cx="12" cy="8" r="3"/><circle cx="5" cy="17" r="2.5"/><circle cx="19" cy="17" r="2.5"/><path d="M10 10.5 6.5 15M14 10.5 17.5 15"/>',
  business:
    '<path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/><path d="M9 10h.01M15 10h.01"/>',
  url: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  globe:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>',
  press:
    '<path d="M4 5h13v14H4z"/><path d="M17 8h3v9a2 2 0 0 1-2 2h-1"/><path d="M7 8h7M7 11h7M7 14h4"/>',
  check:
    '<path d="m5 13 4 4L19 7"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  alert:
    '<path d="M12 3 2 20h20L12 3Z"/><path d="M12 9v5M12 17v.01"/>',
  lock: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>',
};

const d = paths[name] ?? paths.tracing;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
/>
