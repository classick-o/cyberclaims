---
// Line-style forensic/tech icons. Stroke = currentColor so we can tint per service accent.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = '' } = Astro.props;

const paths: Record<string, string> = {
  recovery:
    '<path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v4h4"/><path d="M12 8v4l3 2"/>',
  tracing:
    '<circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><circle cx="17" cy="6" r="1.5"/><path d="M8 7.5 15 17M8 6h7M8 7l7 9"/>',
  forensics:
    '<circle cx="11" cy="11" r="6"/><path d="m20 20-4.3-4.3"/><path d="M11 8v6M8 11h6"/>',
  shield:
    '<path d="M12 3 5 6v5c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>',
  takedown:
    '<rect x="4" y="6" width="16" height="12" rx="2"/><path d="M4 10h16"/><path d="m9 14 6 0M12 14v0"/><path d="m8 3 8 3"/>',
  dispute:
    '<path d="M12 3v18"/><path d="M6 8 3 14h6L6 8ZM18 8l-3 6h6l-3-6Z"/><path d="M4 21h16M8 5h8"/>',
  consultancy:
    '<path d="M4 5h16v11H4z"/><path d="M8 20h8M12 16v4"/><path d="M8 9h8M8 12h5"/>',
  diligence:
    '<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9Z"/><path d="M14 3v6h6"/><path d="m9 14 2 2 4-4"/>',
  social:
    '<circle cx="12" cy="8" r="3"/><circle cx="5" cy="17" r="2.5"/><circle cx="19" cy="17" r="2.5"/><path d="M10 10.5 6.5 15M14 10.5 17.5 15"/>',
  business:
    '<path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/><path d="M9 10h.01M15 10h.01"/>',
  url: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>',
  // For the URL Checker. `url` above is a globe - the exact same path as `globe`, in fact
  // - and a globe says "the internet", not "check this link". A chain link says the one
  // thing the tool is for, and it collides with nothing in the services list.
  link: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  globe:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>',
  press:
    '<path d="M4 5h13v14H4z"/><path d="M17 8h3v9a2 2 0 0 1-2 2h-1"/><path d="M7 8h7M7 11h7M7 14h4"/>',
  check:
    '<path d="m5 13 4 4L19 7"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  alert:
    '<path d="M12 3 2 20h20L12 3Z"/><path d="M12 9v5M12 17v.01"/>',
  lock: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>',
  phone:
    '<path d="M21 16.9v2.6a1.9 1.9 0 0 1-2.1 1.9 18.8 18.8 0 0 1-8.2-2.9 18.5 18.5 0 0 1-5.7-5.7A18.8 18.8 0 0 1 2.1 4.6 1.9 1.9 0 0 1 4 2.5h2.6a1.9 1.9 0 0 1 1.9 1.6 12 12 0 0 0 .7 2.6 1.9 1.9 0 0 1-.5 2L7.6 9.9a15 15 0 0 0 5.7 5.7l1.2-1.2a1.9 1.9 0 0 1 2-.4 12 12 0 0 0 2.6.6 1.9 1.9 0 0 1 1.6 2Z"/>',
  mail:
    '<rect x="2.5" y="5" width="19" height="14" rx="2"/><path d="m3.5 7 7.5 5.2a1.8 1.8 0 0 0 2 0L20.5 7"/>',
  pin:
    '<path d="M20 10.5c0 5.5-8 11.5-8 11.5s-8-6-8-11.5a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10.2" r="2.9"/>',
  user:
    '<circle cx="12" cy="8" r="3.6"/><path d="M4.8 20a7.2 7.2 0 0 1 14.4 0"/>',
  coins:
    '<ellipse cx="12" cy="6.4" rx="7" ry="2.9"/><path d="M5 6.4v5.2c0 1.6 3.1 2.9 7 2.9s7-1.3 7-2.9V6.4"/><path d="M5 11.6v5.2c0 1.6 3.1 2.9 7 2.9s7-1.3 7-2.9v-5.2"/>',
  leaf: '<path d="M4 20c9 1 16-5 16-15-9-1-16 5-16 15Z"/><path d="M4 20c3-6 7-9 12-10"/>',
  cloud:
    '<path d="M7 18a4 4 0 0 1 0-8 5 5 0 0 1 9.6-1.4A3.5 3.5 0 0 1 18 18Z"/>',
  smile:
    '<circle cx="12" cy="12" r="9"/><path d="M8 14.5s1.4 2 4 2 4-2 4-2"/><path d="M9 9.5h.01M15 9.5h.01"/>',
};

const d = paths[name] ?? paths.tracing;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
/>
