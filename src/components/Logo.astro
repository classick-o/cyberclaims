---
// Cyberclaims mark — animated ring (upgrade of the spinning-logo GIF to CSS, brief §2.2).
import { link } from '../lib/paths';
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href={link('/')} class={`logo ${className}`} aria-label="Cyberclaims home">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 40 40" fill="none">
      <circle class="ring ring-outer" cx="20" cy="20" r="17" stroke="url(#lg)" stroke-width="2" stroke-dasharray="18 10" stroke-linecap="round" />
      <circle class="ring ring-inner" cx="20" cy="20" r="11" stroke="#a880d1" stroke-width="1.4" stroke-dasharray="10 8" stroke-linecap="round" opacity="0.8" />
      <circle cx="20" cy="20" r="3.2" fill="#a880d1" />
      <defs>
        <linearGradient id="lg" x1="0" y1="0" x2="40" y2="40">
          <stop stop-color="#8b5bbd" />
          <stop offset="1" stop-color="#6b3fa0" />
        </linearGradient>
      </defs>
    </svg>
  </span>
  <span class="logo-word">Cyber<span class="logo-word-accent">claims</span></span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }
  .logo-mark {
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
  }
  .logo-mark svg {
    width: 100%;
    height: 100%;
  }
  .ring {
    transform-origin: center;
  }
  .ring-outer {
    animation: spin 9s linear infinite;
  }
  .ring-inner {
    animation: spin 6s linear infinite reverse;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .logo-word-accent {
    color: var(--color-purple-300);
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ring-outer,
    .ring-inner {
      animation: none;
    }
  }
</style>
