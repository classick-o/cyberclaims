---
// Cyberclaims mark - animated ring (upgrade of the spinning-logo GIF to CSS, brief §2.2).
import { asset, link } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href={link('/', locale)} class={`logo ${className}`} aria-label="Cyberclaims home">
  <span class="logo-mark" aria-hidden="true">
    <img src={asset('/logo-mark.webp')} alt="" width="40" height="40" />
  </span>
  <span class="logo-word">Cyber<span class="logo-word-accent">claims</span></span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }
  .logo-mark {
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
  }
  .logo-mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .logo-word-accent {
    color: var(--color-purple-300);
  }
</style>
