---
// "We prioritise Sustainability" - preserved from live site, with scroll-triggered counters.
// NOTE: placeholder figures - live site currently shows 0 (see data/site.ts).
import Icon from './Icon.astro';
import { SUSTAINABILITY } from '../data/site';
import { localeFromUrl } from '../i18n/config';
import { useTranslations } from '../i18n';

const t = useTranslations(localeFromUrl(Astro.url));
---

<section class="sus">
  <div class="wrap">
    <div class="sus-head" data-reveal>
      <h2
        class="h-section"
        set:html={t('home.susTitle', { accent: `<span class="accent">${t('home.susTitleA')}</span>` })}
      />
      <p class="sus-lead">{t('home.susLead')}</p>
    </div>

    <div class="sus-grid">
      {
        SUSTAINABILITY.map((s) => (
          <div class="glass sus-card" data-reveal>
            <span class="sus-icon"><Icon name={s.icon} class="w-6 h-6" /></span>
            <div class="sus-text">
              <div class="sus-value">
                <span
                  class="counter"
                  data-target={s.value}
                  data-suffix={s.suffix ?? ''}
                >0</span><span class="sus-fix">{s.suffix}</span>
              </div>
              <div class="sus-label">{t(s.labelKey)}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sus {
    padding: 2.5rem 0 3rem;
    background: var(--color-navy);
  }
  .sus-head {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 3rem;
  }
  .sus-head h2 {
    margin: 0.9rem 0 1rem;
  }
  .sus-lead {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }
  .sus-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  /* compact horizontal cards: icon + text on one row */
  .sus-card {
    padding: 1.1rem 1.35rem;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    transition: transform 0.35s var(--ease-out-brand), border-color 0.35s;
  }
  .sus-card:hover {
    transform: translateY(-5px);
    border-color: rgba(139, 91, 189, 0.4);
  }
  .sus-icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: 0.6rem;
    color: var(--color-purple-300);
    background: rgba(139, 91, 189, 0.14);
    border: 1px solid rgba(139, 91, 189, 0.28);
  }
  .sus-icon :global(svg) {
    width: 1.3rem;
    height: 1.3rem;
  }
  .sus-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }
  .sus-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 2vw, 1.85rem);
    line-height: 1;
    color: #fff;
  }
  .sus-fix {
    color: var(--color-purple-300);
  }
  .sus-label {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
  }
  .sus-grid {
    gap: 0.85rem;
  }
  @media (min-width: 768px) {
    .sus-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  // Animated number counters. Lives here rather than on a page, so the figures
  // count up wherever this section is rendered (homepage, URL checker, ...).
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // The BCP-47 tag Layout.astro stamped on <html> from LOCALE_META. Read it rather
  // than hardcoding 'en-US': the same figure is "1,511" in English and "1.511" in
  // Dutch, and a counter that silently formats every language as American is the kind
  // of thing nobody notices until a customer does.
  const intl = document.documentElement.dataset.intl || 'en-GB';

  const runCounter = (el: HTMLElement) => {
    const raw = el.dataset.target || '0';
    const target = Number(raw);
    // preserve the target's decimal places (e.g. 57.45 stays 57.45, not 57)
    const dec = (raw.split('.')[1] || '').length;
    const fmt = (n: number) =>
      n.toLocaleString(intl, {
        minimumFractionDigits: dec,
        maximumFractionDigits: dec,
      });
    if (reduce) {
      el.textContent = fmt(target);
      return;
    }
    const dur = 1600;
    const start = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
      el.textContent = fmt(target * eased);
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const cio = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          runCounter(e.target as HTMLElement);
          cio.unobserve(e.target);
        }
      });
    },
    { threshold: 0.5 }
  );
  document.querySelectorAll<HTMLElement>('.sus .counter').forEach((c) => cio.observe(c));
</script>
