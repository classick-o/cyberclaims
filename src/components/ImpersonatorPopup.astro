---
// Homepage-only fraud-warning popup.
//
// The "Beware of Impersonators" band (ImpersonatorNotice.astro) sits above the footer on
// every page EXCEPT the homepage. This is the homepage's version of the same warning: a
// bottom-centred popup, over a dimmed backdrop, that appears once per browser session
// four seconds after the first homepage load. Same i18n keys and artwork, so it stays
// translated for free and in sync with the band. The "once per session" state lives in
// sessionStorage - it survives navigating away and back, and resets when the session ends.
import { CONTACT } from '../data/site';
import { asset } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import { useTranslations } from '../i18n';

const t = useTranslations(localeFromUrl(Astro.url));
---

<div id="imp-popup" class="imp-pop-root" hidden>
  <div class="imp-pop-backdrop" aria-hidden="true"></div>

  <div
    class="imp-pop"
    role="dialog"
    aria-modal="true"
    aria-labelledby="imp-pop-title"
    aria-describedby="imp-pop-desc"
  >
    <div class="imp-pop-art">
      <span class="imp-pop-glow" aria-hidden="true"></span>
      <img
        class="imp-pop-img"
        src={asset('/notice/beware.webp')}
        alt=""
        aria-hidden="true"
        width="180"
        height="180"
        loading="lazy"
      />
    </div>

    <div class="imp-pop-text" id="imp-pop-desc">
      <h3 class="imp-pop-title" id="imp-pop-title">{t('impersonator.title')}</h3>
      <p>{t('impersonator.body1')}</p>
      <p><strong>{t('impersonator.body2')}</strong></p>
      <p
        set:html={t('impersonator.body3', {
          email: `<a href="mailto:${CONTACT.email}">${CONTACT.email}</a>`,
        })}
      />
    </div>

    <button class="imp-pop-close" type="button" aria-label={t('nav.close')}>
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>
  </div>
</div>

<style>
  /* full-viewport layer: dim the page, hold the card. While open it sits above
     everything (header included) so the whole page reads as inert behind it. */
  .imp-pop-root {
    position: fixed;
    inset: 0;
    z-index: 200;
  }
  .imp-pop-root[hidden] {
    display: none;
  }

  /* While the popup is open the page underneath is frozen - no scrolling. `overflow:
     hidden` on <html> (which is the scroll root here: html/body use overflow-x: clip, so
     html is what actually scrolls), plus padding-right equal to the now-removed scrollbar
     so the page doesn't jump sideways the moment the bar disappears. */
  :global(html.imp-pop-open) {
    overflow: hidden;
    padding-right: var(--imp-sbw, 0px);
  }

  /* the darker screen over the page content */
  .imp-pop-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 8, 15, 0.62);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.45s var(--ease-out-brand);
  }
  .imp-pop-root.is-visible .imp-pop-backdrop {
    opacity: 1;
  }

  .imp-pop {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    /* translateX centres it; translateY is the slide-in offset (0 when visible) */
    transform: translateX(-50%) translateY(1.75rem);
    width: min(41rem, calc(100vw - 1.75rem));
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.35rem 1.6rem;
    border-radius: 1.1rem;
    overflow: hidden;
    color: rgba(255, 255, 255, 0.74);
    background:
      radial-gradient(70% 130% at 0% 50%, rgba(240, 170, 60, 0.16), transparent 60%),
      linear-gradient(180deg, rgba(26, 22, 34, 0.94), rgba(18, 16, 26, 0.96));
    border: 1px solid rgba(240, 170, 60, 0.34);
    box-shadow:
      0 26px 60px -22px rgba(0, 0, 0, 0.8),
      0 0 44px -18px rgba(240, 170, 60, 0.5);
    opacity: 0;
    transition: opacity 0.45s var(--ease-out-brand),
      transform 0.55s var(--ease-out-brand);
  }
  .imp-pop-root.is-visible .imp-pop {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* artwork */
  .imp-pop-art {
    position: relative;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 5.25rem;
    height: 5.25rem;
  }
  .imp-pop-glow {
    position: absolute;
    inset: 50% auto auto 50%;
    width: 5rem;
    height: 5rem;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(240, 170, 60, 0.5), transparent 65%);
    filter: blur(14px);
    pointer-events: none;
  }
  .imp-pop-img {
    position: relative;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 10px 18px rgba(120, 70, 10, 0.5));
  }

  /* text */
  .imp-pop-text {
    min-width: 0;
  }
  .imp-pop-title {
    font-size: 1.08rem;
    color: #f4c47a;
    margin: 0 0 0.4rem;
  }
  .imp-pop-text p {
    line-height: 1.55;
    font-size: 0.85rem;
    margin: 0 0 0.4rem;
  }
  .imp-pop-text p:last-child {
    margin-bottom: 0;
  }
  .imp-pop-text strong {
    color: #fff;
    font-weight: 600;
  }
  .imp-pop-text :global(a) {
    color: #f4c47a;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* close */
  .imp-pop-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    display: grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    padding: 0;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }
  .imp-pop-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 560px) {
    .imp-pop {
      bottom: 0.85rem;
      gap: 0.9rem;
      padding: 1.2rem 1.2rem 1.25rem;
    }
    /* the artwork is decorative - drop it on narrow screens and give the text the room */
    .imp-pop-art {
      display: none;
    }
    .imp-pop-title {
      /* keep the heading clear of the close button */
      padding-right: 1.6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .imp-pop-backdrop,
    .imp-pop {
      transition: opacity 0.2s linear;
    }
    .imp-pop,
    .imp-pop-root.is-visible .imp-pop {
      transform: translateX(-50%) translateY(0);
    }
  }
</style>

<script>
  // Show once per session, 4s after the first homepage load. sessionStorage survives
  // in-session navigation (so returning to the homepage won't show it again) and clears
  // when the session ends. The flag is written only when the popup actually appears, so a
  // visitor who leaves within the 4s still gets the warning on a later homepage visit.
  const KEY = 'cc-impersonator-popup-seen';
  const root = document.getElementById('imp-popup');

  if (root && !sessionStorage.getItem(KEY)) {
    const dialog = root.querySelector<HTMLElement>('.imp-pop');
    const closeBtn = root.querySelector<HTMLButtonElement>('.imp-pop-close');
    const docEl = document.documentElement;
    let lastFocus: HTMLElement | null = null;

    // Freeze the page behind the popup - no scrolling while it's open. Reserve the width
    // of the scrollbar that `overflow: hidden` removes, so the page doesn't jump sideways.
    const lockScroll = () => {
      const scrollbar = window.innerWidth - docEl.clientWidth;
      docEl.style.setProperty('--imp-sbw', `${scrollbar}px`);
      docEl.classList.add('imp-pop-open');
    };
    const unlockScroll = () => {
      docEl.classList.remove('imp-pop-open');
      docEl.style.removeProperty('--imp-sbw');
    };

    const show = () => {
      lastFocus = document.activeElement as HTMLElement | null;
      root.hidden = false;
      lockScroll();
      // let the browser paint the hidden->shown base state before transitioning
      requestAnimationFrame(() => root.classList.add('is-visible'));
      sessionStorage.setItem(KEY, '1');
      // move focus into the dialog (it's modal now); preventScroll so the page doesn't jump
      closeBtn?.focus({ preventScroll: true });
    };

    const hide = () => {
      root.classList.remove('is-visible');
      unlockScroll();
      // remove from the a11y tree once the fade-out has run (timeout, not transitionend,
      // so it still fires under prefers-reduced-motion where no transition may complete)
      window.setTimeout(() => {
        root.hidden = true;
      }, 450);
      lastFocus?.focus?.({ preventScroll: true });
    };

    const timer = window.setTimeout(show, 4000);

    // The X button is the ONLY way to dismiss it - no backdrop-click, no Escape.
    closeBtn?.addEventListener('click', hide);

    // Keep Tab within the dialog while it's the modal on top.
    document.addEventListener('keydown', (e) => {
      if (root.hidden || e.key !== 'Tab' || !dialog) return;
      const items = Array.from(
        dialog.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      );
      if (items.length === 0) return;
      const first = items[0];
      const last = items[items.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    // Don't fire the timer into a half-torn-down document if the page is left early.
    window.addEventListener('pagehide', () => window.clearTimeout(timer), { once: true });
  }
</script>
