---
// Latest articles - 3 cards (brief §4 News card spec).
//
// Rendered as a SERVER ISLAND: <Blogs server:defer /> in index.astro. The homepage
// stays prerendered HTML on disk - so it keeps serving even if MySQL is down - and
// only this strip renders on the server, on demand. Making the whole homepage SSR
// just to show three cards would have put the site's most-hit page behind a database.
//
// It used to render three cards hardcoded in site.ts, whose links all 404'd because
// no /news/[slug] route existed.
import Cover from './Cover.astro';
import Icon from './Icon.astro';
import { link } from '../lib/paths';
import { Post, cached, type PostCard } from '../lib/content';
import { localeFromUrl, DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { useTranslations, formatDate } from '../i18n';

// A server island (`server:defer`) renders in its OWN request to /_server-islands/…, so
// Astro.url is that endpoint, not the page - localeFromUrl(Astro.url) would always read
// 'en' and the strip would show English headings and English article links on /nl/,
// /fr/, … . The homepage passes the resolved locale in as a prop; the fallback covers
// any non-island use.
const { locale = localeFromUrl(Astro.url) } = Astro.props as { locale?: Locale };
const t = useTranslations(locale);

// If the database is unreachable the island renders nothing rather than throwing -
// the point of keeping the homepage static is that it survives a bad day downstream.
let posts = (await cached(`latest:${locale}`, () =>
  Post.findPublished(locale, { limit: 3 })
).catch(() => [])) as PostCard[];

// Fall back to the default locale's articles when this language has none of its own yet.
// Otherwise every non-English homepage launches with the whole "Latest" section missing
// until someone has translated an article - an English card with a working link beats a
// hole in the page. Once localised articles exist, they take over automatically.
const articlesLocale = posts.length > 0 ? locale : DEFAULT_LOCALE;
if (posts.length === 0 && locale !== DEFAULT_LOCALE) {
  posts = (await cached(`latest:${DEFAULT_LOCALE}`, () =>
    Post.findPublished(DEFAULT_LOCALE, { limit: 3 })
  ).catch(() => [])) as PostCard[];
}
---

{
  posts.length > 0 && (
    <section class="blogs">
      <div class="wrap">
        <div class="blogs-head" data-reveal>
          <div>
            <h2
              class="h-section"
              set:html={t('home.blogsTitle', { accent: `<span class="accent">${t('home.blogsTitleA')}</span>` })}
            />
          </div>
          <a href={link('/news/', locale)} class="btn">
            {t('home.blogsAll')}
          </a>
        </div>

        <div class="blogs-grid">
          {posts.map((p) => (
            <a href={link(`/${p.slug}/`, articlesLocale)} class="blog-card" data-reveal>
              <div class="cover blog-thumb">
                {p.category_name && <span class="blog-cat">{p.category_name}</span>}
                <Cover
                  path={p.cover_path}
                  variants={p.cover_variants}
                  alt={p.cover_alt}
                  sizes="(min-width: 768px) 30vw, 100vw"
                />
              </div>
              <div class="blog-body">
                <div class="blog-meta">
                  <time datetime={new Date(p.published_at).toISOString()}>
                    {formatDate(p.published_at, locale)}
                  </time>
                  <span class="blog-dot">·</span>
                  <span>{t('news.readingTime', { minutes: p.reading_minutes })}</span>
                </div>
                <h3 class="blog-title">{p.title}</h3>
                <span class="blog-more">
                  {t('cta.readMore')} <Icon name="arrow" class="w-4 h-4" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .blogs {
    padding: 3rem 0;
    background: var(--color-navy);
  }
  .blogs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.75rem;
  }
  /* on phones: keep heading + button on the SAME row (button to the right),
     centered vertically and compact so it doesn't blow up */
  @media (max-width: 640px) {
    .blogs-head {
      align-items: center;
      gap: 1rem;
    }
    .blogs-head .btn {
      flex-shrink: 0;
      align-self: center;
      padding: 0.6rem 1.1rem;
      font-size: 0.82rem;
    }
  }
  .blogs-head h2 {
    margin-top: 0.9rem;
  }
  .blogs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(35, 35, 64, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out-brand),
      border-color 0.35s, box-shadow 0.35s;
  }
  .blog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 91, 189, 0.4);
    box-shadow: 0 24px 48px -22px rgba(0, 0, 0, 0.6);
  }
  .blog-thumb {
    aspect-ratio: 16 / 9;
  }
  .blog-cat {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(107, 63, 160, 0.85);
    backdrop-filter: blur(4px);
  }
  .blog-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .blog-dot {
    color: var(--color-purple-300);
  }
  .blog-title {
    font-size: 1.1rem;
    line-height: 1.35;
    color: #fff;
    flex: 1;
  }
  .blog-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-purple-300);
  }
  .blog-more :global(svg) {
    transition: transform 0.3s var(--ease-out-brand);
  }
  .blog-card:hover .blog-more :global(svg) {
    transform: translateX(4px);
  }
  @media (min-width: 768px) {
    .blogs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
