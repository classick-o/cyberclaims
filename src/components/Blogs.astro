---
// Latest blogs - 3 cards with category tag, date, author (brief §4 News card spec).
import Icon from './Icon.astro';
import { LATEST_BLOGS } from '../data/site';
import { link } from '../lib/paths';
---

<section class="blogs">
  <div class="wrap">
    <div class="blogs-head" data-reveal>
      <div>
        <span class="eyebrow">Articles</span>
        <h2 class="h-section">Latest <span class="accent">blogs</span></h2>
      </div>
      <a href={link('/news/')} class="btn btn-ghost">All news</a>
    </div>

    <div class="blogs-grid">
      {
        LATEST_BLOGS.map((b) => (
          <a href={link(b.href)} class="blog-card" data-reveal>
            <div class="blog-thumb">
              <span class="blog-cat">{b.category}</span>
              <!-- image placeholder (client-supplied 16:9) -->
              <div class="blog-thumb-ph"><Icon name="press" class="w-8 h-8" /></div>
            </div>
            <div class="blog-body">
              <div class="blog-meta">
                <span>{b.date}</span>
                <span class="blog-dot">·</span>
                <span>by {b.author}</span>
              </div>
              <h3 class="blog-title">{b.title}</h3>
              <span class="blog-more">Read more <Icon name="arrow" class="w-4 h-4" /></span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .blogs {
    padding: 6rem 0;
    background: var(--color-navy);
  }
  .blogs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.75rem;
  }
  .blogs-head h2 {
    margin-top: 0.9rem;
  }
  .blogs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(35, 35, 64, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out-brand),
      border-color 0.35s, box-shadow 0.35s;
  }
  .blog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 91, 189, 0.4);
    box-shadow: 0 24px 48px -22px rgba(0, 0, 0, 0.6);
  }
  .blog-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #232340, #101020);
    overflow: hidden;
  }
  .blog-thumb-ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: rgba(168, 128, 209, 0.35);
  }
  .blog-cat {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(107, 63, 160, 0.85);
    backdrop-filter: blur(4px);
  }
  .blog-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .blog-dot {
    color: var(--color-purple-300);
  }
  .blog-title {
    font-size: 1.1rem;
    line-height: 1.35;
    color: #fff;
    flex: 1;
  }
  .blog-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-purple-300);
  }
  .blog-more :global(svg) {
    transition: transform 0.3s var(--ease-out-brand);
  }
  .blog-card:hover .blog-more :global(svg) {
    transform: translateX(4px);
  }
  @media (min-width: 768px) {
    .blogs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
