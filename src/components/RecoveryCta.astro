---
// "Start Your Recovery Now" CTA block - preserved from live homepage (between About & Services).
import Icon from './Icon.astro';
import { link } from '../lib/paths';
---

<section class="rec">
  <div class="wrap">
    <div class="glass rec-card" data-reveal>
      <div class="glow-blob" style="background:#6b3fa0;width:22rem;height:22rem;top:-8rem;left:-4rem;opacity:0.3;"></div>

      <!-- Dot grid with a glow that sweeps across, lighting up the dots -->
      <div class="rec-dots" aria-hidden="true">
        <span class="dots-base"></span>
        <span class="dots-glow"></span>
      </div>

      <div class="rec-content">
        <div class="rec-left">
          <h2 class="rec-title">Start your <span class="accent">recovery</span> now</h2>
          <p class="rec-sub">
            Talk to a certified expert about your case. No obligation - just a clear picture
            of your options and next steps.
          </p>
        </div>
        <div class="rec-actions">
          <a href={link('/start-process/')} class="btn">Start Process <Icon name="arrow" class="w-4 h-4" /></a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rec {
    /* transparent - the shared .about-block gradient shows through, so the area
       around the card is a seamless continuation of the About section above */
    padding: 0 0 2.5rem;
    background: transparent;
  }
  .rec-card {
    position: relative;
    overflow: hidden;
    padding: 2.5rem;
    /* opaque: override .glass's translucent fill + backdrop blur, so whatever
       sits behind the card (page gradient, aurora) doesn't show through it.
       rgb(35,35,64) is the same colour .glass uses, just at full alpha. */
    background: var(--color-navy-elevated);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  @media (max-width: 640px) {
    .rec-card {
      padding: 1.75rem 1.25rem;
    }
  }
  /* dot grid + sweeping glow */
  .rec-dots {
    position: absolute;
    inset: 0 0 0 auto;
    width: 62%;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to left, #000 42%, transparent);
    mask-image: linear-gradient(to left, #000 42%, transparent);
  }
  .dots-base,
  .dots-glow {
    position: absolute;
    inset: -2px;
    background-image: radial-gradient(circle, currentColor 1.4px, transparent 1.6px);
    background-size: 26px 26px;
  }
  /* faint always-on dots */
  .dots-base {
    color: rgba(168, 128, 209, 0.16);
  }
  /* bright dots revealed only under the moving spotlight */
  .dots-glow {
    color: rgba(206, 182, 230, 0.85);
    -webkit-mask-image: radial-gradient(circle, #000 0%, transparent 60%);
    mask-image: radial-gradient(circle, #000 0%, transparent 60%);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 360px 360px;
    mask-size: 360px 360px;
    animation: dot-sweep 9s ease-in-out infinite;
    will-change: mask-position;
  }
  @keyframes dot-sweep {
    0% {
      -webkit-mask-position: 110% 120%;
      mask-position: 110% 120%;
    }
    50% {
      -webkit-mask-position: 15% -10%;
      mask-position: 15% -10%;
    }
    100% {
      -webkit-mask-position: 110% 120%;
      mask-position: 110% 120%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .dots-glow {
      animation: none;
      -webkit-mask-position: 50% 50%;
      mask-position: 50% 50%;
    }
  }

  .rec-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  .rec-title {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    margin: 0 0 0.7rem;
    color: #fff;
  }
  .rec-sub {
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.6;
    max-width: 44ch;
  }
  .rec-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
  @media (min-width: 900px) {
    .rec-content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .rec-actions {
      flex-shrink: 0;
      flex-direction: column;
    }
  }
</style>
