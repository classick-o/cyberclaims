---
// "Start Your Recovery Now" CTA block - preserved from live homepage (between About & Services).
import Icon from './Icon.astro';
import DotGrid from './DotGrid.astro';
import { link } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import { useTranslations } from '../i18n';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section class="rec">
  <div class="wrap">
    <div class="glass rec-card" data-reveal>
      <div class="glow-blob" style="background:#6b3fa0;width:22rem;height:22rem;top:-8rem;left:-4rem;opacity:0.3;"></div>

      <DotGrid width="62%" fade="left" />

      <div class="rec-content">
        <div class="rec-left">
          <h2
            class="rec-title"
            set:html={t('home.recTitle', { accent: `<span class="accent">${t('home.recTitleA')}</span>` })}
          />
          <p class="rec-sub">{t('home.recSub')}</p>
        </div>
        <div class="rec-actions">
          <a href={link('/start-process/', locale)} class="btn">{t('cta.startProcess')} <Icon name="arrow" class="w-4 h-4" /></a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rec {
    /* transparent - the shared .about-block gradient shows through, so the area
       around the card is a seamless continuation of the About section above */
    padding: 0 0 2.5rem;
    background: transparent;
  }
  .rec-card {
    position: relative;
    overflow: hidden;
    padding: 2.5rem;
    /* opaque: override .glass's translucent fill + backdrop blur, so whatever
       sits behind the card (page gradient, aurora) doesn't show through it.
       rgb(35,35,64) is the same colour .glass uses, just at full alpha. */
    background: var(--color-navy-elevated);
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
  }
  @media (max-width: 640px) {
    .rec-card {
      padding: 1.75rem 1.25rem;
    }
  }
  .rec-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  .rec-title {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    margin: 0 0 0.7rem;
    color: #fff;
  }
  .rec-sub {
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.6;
    max-width: 44ch;
  }
  .rec-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
  @media (min-width: 900px) {
    .rec-content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .rec-actions {
      flex-shrink: 0;
      flex-direction: column;
    }
  }
</style>
