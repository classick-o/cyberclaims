---
// Featured "Crypto Currency Tracing" highlight - alternating layout (visual left, text right).
import Icon from './Icon.astro';
import DotGrid from './DotGrid.astro';
import TraceGraph from './TraceGraph.astro';
import { link, serviceUrl } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import { useTranslations } from '../i18n';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section class="tracing">
  <div class="wrap tracing-stack">
    <div class="tracing-copy" data-reveal>
      <h2
        class="h-section"
        set:html={t('home.tracingTitle', { accent: `<span class="accent">${t('home.tracingTitleA')}</span>` })}
      />
      <div class="tracing-row">
        <p class="tracing-body">{t('home.tracingBody')}</p>
        {/* serviceUrl(), not the bare href. The service `href` in site.ts is the internal
            KEY ('/cryptocurrency-tracing/') used to look up content and images - the page
            itself lives at /services/cryptocurrency-tracing/. Linking straight to the key
            sent this button to a URL that has never existed. */}
        <a href={link(serviceUrl('/cryptocurrency-tracing/'), locale)} class="btn">{t('home.tracingViewMore')}</a>
      </div>
    </div>

    <div class="tracing-visual">
      <div class="glass tw-card">
        {/* Dimmer than the CTA strip's 0.16: there the grid is the only thing in that half of
            the card, here it sits under a seven-node graph and competes with it. */}
        <DotGrid opacity={0.11} />

        <div class="tw-inner">
          <div class="tw-row">
            <span class="tw-chip"><Icon name="tracing" class="w-4 h-4" /> {t('home.tracingChip1')}</span>
            <span class="tw-chip"><Icon name="globe" class="w-4 h-4" /> {t('home.tracingChip2')}</span>
            <span class="tw-chip"><Icon name="lock" class="w-4 h-4" /> {t('home.tracingChip3')}</span>
          </div>
          <TraceGraph />
          <div class="tw-foot">{t('home.tracingFoot')}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tracing {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  /* Stacked, not side-by-side: the graph is seven nodes wide and only reads properly with the
     full column to itself. Copy sits above it, centred. */
  .tracing-stack {
    position: relative;
    z-index: 1;
  }
  .tracing-visual,
  .tracing-copy {
    min-width: 0;
  }
  .tracing-copy {
    margin-bottom: 2.5rem;
  }
  /* Body left, button right, sharing one baseline row - the button would otherwise sit under a
     70ch paragraph and leave a wide dead strip beside it. */
  .tracing-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2.5rem;
  }
  .tracing-row .btn {
    flex: none;
  }
  .tw-card {
    position: relative;
    /* clips the dot grid to the card's rounded corners */
    overflow: hidden;
    padding: 1.75rem;
    /* same frosted treatment as the hero form: more opaque so it reads as a
       solid frosted panel even where GPU blur is weak/unavailable */
    background: rgba(22, 22, 42, 0.62);
    -webkit-backdrop-filter: blur(26px) saturate(150%);
    backdrop-filter: blur(26px) saturate(150%);
  }
  /* lifts the chips, graph and caption above the dot grid */
  .tw-inner {
    position: relative;
    z-index: 2;
  }
  .tw-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .tw-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.75);
    background: rgba(139, 91, 189, 0.12);
    border: 1px solid rgba(139, 91, 189, 0.25);
  }
  .tw-chip :global(svg) {
    width: 0.9rem;
    height: 0.9rem;
    color: var(--color-purple-300);
  }
  .tw-foot {
    margin-top: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .tracing-body {
    margin: 1.2rem 0 0;
    max-width: 72ch;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.7;
  }
  /* Below the tablet breakpoint the button drops under the paragraph rather than squeezing it. */
  @media (max-width: 767px) {
    .tracing-row {
      flex-direction: column;
      align-items: stretch;
      gap: 1.5rem;
    }
    .tracing-row .btn {
      align-self: flex-start;
    }
  }
  /* Below 900px the graph flips to the narrow four-node chain, so the card shrinks to hug it.
     Left full-width, the vertical graph floated in a mostly empty panel. */
  @media (max-width: 899px) {
    .tw-card {
      max-width: 32rem;
      margin-inline: auto;
    }
  }
  @media (max-width: 640px) {
    .tw-card {
      padding: 1.25rem;
    }
  }
</style>
