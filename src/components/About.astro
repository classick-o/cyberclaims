---
// "Hello, We Are Cyberclaims" - split section: copy left, animated blockchain-trace SVG right.
import Aurora from './Aurora.astro';
import Icon from './Icon.astro';
import { asset, link } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import { useTranslations } from '../i18n';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
const t = useTranslations(locale);

const points = [t('home.aboutPoint1'), t('home.aboutPoint2'), t('home.aboutPoint3')];
---

<section class="about">
  <Aurora />
  <div class="wrap about-grid">
    <div class="about-copy" data-reveal>
      <h2
        class="h-section about-title"
        set:html={t('home.aboutTitle', { accent: `<span class="accent">${t('home.aboutTitleA')}</span>` })}
      />
      <p class="about-lead">{t('home.aboutLead')}</p>
      <p class="about-body">{t('home.aboutBody')}</p>
      <ul class="about-points">
        {
          points.map((p) => (
            <li>
              <span class="pt-icon"><Icon name="check" class="w-4 h-4" /></span>
              {p}
            </li>
          ))
        }
      </ul>
      <div class="about-cta">
        <a href={link('/about-us/', locale)} class="btn">{t('cta.readMore')}</a>
      </div>
    </div>

    <!-- Blockchain funds-flow trace visual -->
    <div class="about-visual" data-reveal>
      <div class="trace-frame">
        <img
          class="trace-img"
          src={asset('/funds-flow.webp')}
          alt={t('home.aboutImageAlt')}
          width="2048"
          height="2048"
          loading="lazy"
        />
      </div>
      <div class="glow-blob trace-glow" style="background:#6b3fa0;width:20rem;height:20rem;top:50%;left:50%;z-index:-1;"></div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    padding: 3rem 0;
    background: transparent;
  }
  /* No `overflow:hidden` here: this section shares the .about-block gradient with
     RecoveryCta below, so there is no solid colour to fade a clipped edge back
     into. Letting the aurora spill downward lets its own mask finish the fade,
     and RecoveryCta paints over it afterwards. */
  .about > .wrap {
    position: relative;
    z-index: 1;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .about-copy,
  .about-visual {
    min-width: 0;
  }
  .about-title {
    margin: 0 0 1.4rem;
  }
  .about-lead {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 1rem;
  }
  .about-body {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.65;
    margin-bottom: 1.6rem;
  }
  .about-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }
  .about-points li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
  }
  .pt-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: rgba(139, 91, 189, 0.15);
    color: var(--color-purple-300);
  }
  .about-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .about-visual {
    position: relative;
  }
  .trace-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 38rem;
    margin-inline: auto;
    display: grid;
    place-items: center;
  }
  .trace-img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 38rem;
    object-fit: contain;
  }
  /* subtle pulsing glow behind the illustration */
  .trace-glow {
    animation: trace-pulse 5s ease-in-out infinite;
  }
  @keyframes trace-pulse {
    0%,
    100% {
      opacity: 0.22;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.42;
      transform: translate(-50%, -50%) scale(1.12);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .trace-glow {
      animation: none;
      opacity: 0.3;
      transform: translate(-50%, -50%);
    }
  }
  /* center the copy on mobile & tablet (single-column layout) */
  @media (max-width: 1023px) {
    .about-copy {
      text-align: center;
    }
    /* keep the checklist reading left-to-right, but center the block */
    .about-points {
      align-items: flex-start;
      text-align: left;
      width: fit-content;
      max-width: 100%;
      margin-inline: auto;
    }
    .about-cta {
      justify-content: center;
    }
  }
  /* tighten the gap between copy and the visual on phones */
  @media (max-width: 767px) {
    .about-grid {
      gap: 1rem;
    }
  }
  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4.5rem;
    }
  }
</style>
