---
// "Hello, We Are Cyberclaims" - split section: copy left, animated blockchain-trace SVG right.
import Aurora from './Aurora.astro';
import Icon from './Icon.astro';
import { link } from '../lib/paths';

const points = [
  'Certified experts in crypto & blockchain forensics',
  'Global reach - work with you from anywhere',
  'Free case review with a 48-hour response',
];
---

<section class="about">
  <Aurora />
  <div class="wrap about-grid">
    <div class="about-copy" data-reveal>
      <h2 class="h-section about-title">
        Hello, we are <span class="accent">Cyberclaims</span>
      </h2>
      <p class="about-lead">
        At Cyberclaims, you can rely on our team of dedicated and certified experts to
        provide and implement the best solutions for the challenges hindering your
        business’s growth.
      </p>
      <p class="about-body">
        If you are a victim of cyber fraud or have lost digital assets due to cyber theft,
        reaching out to us is the first step toward recovering your assets and getting the
        support you need.
      </p>
      <ul class="about-points">
        {
          points.map((p) => (
            <li>
              <span class="pt-icon"><Icon name="check" class="w-4 h-4" /></span>
              {p}
            </li>
          ))
        }
      </ul>
      <div class="about-cta">
        <a href={link('/about-us/')} class="btn">Read More</a>
      </div>
    </div>

    <!-- Blockchain funds-flow trace visual -->
    <div class="about-visual" data-reveal>
      <div class="trace-frame">
        <img
          class="trace-img"
          src={link('/funds-flow.webp')}
          alt="Live blockchain funds-flow trace: wallet, exchange and mixer nodes linked to a flagged cashout point"
          width="2048"
          height="2048"
          loading="lazy"
        />
      </div>
      <div class="glow-blob trace-glow" style="background:#6b3fa0;width:20rem;height:20rem;top:50%;left:50%;z-index:-1;"></div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    padding: 3rem 0;
    background: transparent;
  }
  /* No `overflow:hidden` here: this section shares the .about-block gradient with
     RecoveryCta below, so there is no solid colour to fade a clipped edge back
     into. Letting the aurora spill downward lets its own mask finish the fade,
     and RecoveryCta paints over it afterwards. */
  .about > .wrap {
    position: relative;
    z-index: 1;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .about-copy,
  .about-visual {
    min-width: 0;
  }
  .about-title {
    margin: 0 0 1.4rem;
  }
  .about-lead {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 1rem;
  }
  .about-body {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.65;
    margin-bottom: 1.6rem;
  }
  .about-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }
  .about-points li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
  }
  .pt-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: rgba(139, 91, 189, 0.15);
    color: var(--color-purple-300);
  }
  .about-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .about-visual {
    position: relative;
  }
  .trace-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 38rem;
    margin-inline: auto;
    display: grid;
    place-items: center;
  }
  .trace-img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 38rem;
    object-fit: contain;
  }
  /* subtle pulsing glow behind the illustration */
  .trace-glow {
    animation: trace-pulse 5s ease-in-out infinite;
  }
  @keyframes trace-pulse {
    0%,
    100% {
      opacity: 0.22;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.42;
      transform: translate(-50%, -50%) scale(1.12);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .trace-glow {
      animation: none;
      opacity: 0.3;
      transform: translate(-50%, -50%);
    }
  }
  /* center the copy on mobile & tablet (single-column layout) */
  @media (max-width: 1023px) {
    .about-copy {
      text-align: center;
    }
    /* keep the checklist reading left-to-right, but center the block */
    .about-points {
      align-items: flex-start;
      text-align: left;
      width: fit-content;
      max-width: 100%;
      margin-inline: auto;
    }
    .about-cta {
      justify-content: center;
    }
  }
  /* tighten the gap between copy and the visual on phones */
  @media (max-width: 767px) {
    .about-grid {
      gap: 1rem;
    }
  }
  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4.5rem;
    }
  }
</style>
