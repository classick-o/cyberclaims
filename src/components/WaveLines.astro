---
// Animated horizontal wave-line field that fades into depth (toward the top).
// Reusable ambient background. Pure CSS transform animation (GPU, smooth).
interface Props {
  color?: string;
  opacityBoost?: number;
}
const { color = '#8b5bbd', opacityBoost = 1 } = Astro.props;
const W = 1200;
const H = 440;
const N = 16; // number of lines
const WL = 420; // wavelength (translate loops by exactly this -> seamless)
const STEP = 24;

function wavePath(y: number, amp: number): string {
  let d = '';
  for (let x = -WL; x <= W + WL; x += STEP) {
    const yy = y + Math.sin((x / WL) * Math.PI * 2) * amp;
    d += (x === -WL ? `M${x} ${yy.toFixed(1)}` : ` L${x} ${yy.toFixed(1)}`);
  }
  return d;
}

// i = 0 -> far/faint/flat (top), i = N-1 -> near/bright/tall (bottom)
const lines = Array.from({ length: N }, (_, i) => {
  const t = i / (N - 1);
  const y = H * (0.1 + 0.9 * Math.pow(t, 1.4)); // denser toward the top (depth)
  const amp = 4 + t * 18;
  const opacity = ((0.04 + t * 0.11) * opacityBoost).toFixed(3);
  return { d: wavePath(y, amp), opacity };
});
---

<div class="waves" aria-hidden="true">
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none">
    <g class="wave-group">
      {
        lines.map((l) => (
          <path class="wl" d={l.d} fill="none" stroke={color} stroke-width="1.2" style={`opacity:${l.opacity}`} />
        ))
      }
    </g>
  </svg>
</div>

<style>
  .waves {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* fade at both ends so lines dissolve into depth (top) and don't harden at the bottom */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 22%, #000 78%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, #000 22%, #000 78%, transparent 100%);
  }
  .waves svg {
    /* keep a minimum natural width so the wave field isn't squashed into steep
       zig-zags on narrow (mobile) viewports; the overflow is clipped */
    width: max(100%, 60rem);
    height: 100%;
    display: block;
  }
  /* fine dashed contour lines = data-stream / tech texture.
     period 10 (3+7) divides the 420 wavelength, so the drift stays seamless. */
  .wl {
    stroke-dasharray: 3 7;
  }
  .wave-group {
    animation: wave-flow 16s linear infinite;
  }
  @keyframes wave-flow {
    to {
      transform: translateX(-420px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wave-group {
      animation: none;
    }
  }
</style>
