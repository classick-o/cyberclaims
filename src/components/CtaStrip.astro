---
// Final conversion CTA strip with diagonal top edge + mesh glow.
import { link } from '../lib/paths';
import { localeFromUrl } from '../i18n/config';
import WaveLines from './WaveLines.astro';

// Resolved from the URL rather than threaded down as a prop: link(, locale) is called across
// 14 components, and a prop that one of them forgets to pass renders another
// language's URLs on the page without erroring.
const locale = localeFromUrl(Astro.url);
---

<section class="cta">
  <div class="cta-inner glass">
    <WaveLines color="#ffffff" opacityBoost={2.4} />
    <div class="glow-blob" style="background:#6b3fa0;width:26rem;height:26rem;top:-8rem;right:-4rem;opacity:0.4;"></div>
    <div class="wrap cta-content">
      <h2 class="h-section cta-title" data-reveal>
        Have you been a victim of <span class="accent">crypto scams?</span>
      </h2>
      <p class="cta-sub" data-reveal>We can help you trace &amp; freeze your assets. Act now.</p>
      <div class="cta-actions">
        <a href={link('/start-process/', locale)} class="btn">Start Process</a>
        <a href={link('/contact-us/', locale)} class="btn btn-ghost">Contact Us</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 2rem 0 0;
    background: var(--color-navy-deep);
  }
  .cta-inner {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    border-inline: none;
    background: var(--gradient-brand);
    border: none;
    padding: 2.5rem 0;
  }
  .cta-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .cta-title {
    color: #fff;
    max-width: 20ch;
    margin-inline: auto;
  }
  .cta-title .accent {
    color: #e3d5f0;
  }
  .cta-sub {
    margin: 1.1rem 0 2rem;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
  }
  .cta-actions .btn {
    background: var(--color-navy);
    color: #fff;
    box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.5);
  }
  .cta-actions .btn:hover {
    background: var(--color-navy-deep);
  }
  .cta-actions .btn-ghost {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.45);
    /* frosted: blur the purple strip + wave lines behind the button */
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    backdrop-filter: blur(10px) saturate(140%);
  }
  .cta-actions .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.24);
  }
</style>
