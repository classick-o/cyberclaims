---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaStrip from '../components/CtaStrip.astro';
import Icon from '../components/Icon.astro';
import { LATEST_BLOGS } from '../data/site';
import { link } from '../lib/paths';
---

<Layout
  title="News - Cyberclaims"
  description="The latest guides, scam reviews and security research from the Cyberclaims team."
>
  <PageHero
    eyebrow="Insights & research"
    title="News"
    intro={[
      'Guides, scam reviews and security research from our investigation team - so you can spot fraud early and stay a step ahead.',
    ]}
    image="/news-hero.webp"
    imageAlt="Floating tiles showing a newspaper, magnifier, warning flag and shield"
    imageMaxWidth="24rem"
    imageMaxWidthMobile="17rem"
  />

  <section class="news">
    <div class="wrap">
      <div class="news-grid">
        {
          LATEST_BLOGS.map((b) => (
            <a href={link(b.href)} class="news-card" data-reveal>
              <div class="news-thumb">
                <span class="news-cat">{b.category}</span>
                <div class="news-thumb-ph" role="img" aria-label="Image placeholder">
                  <Icon name="press" class="w-8 h-8" />
                </div>
              </div>
              <div class="news-body">
                <div class="news-meta">
                  <span>{b.date}</span>
                  <span class="news-dot">·</span>
                  <span>by {b.author}</span>
                </div>
                <h2 class="news-title">{b.title}</h2>
                <span class="news-more">
                  Read more <Icon name="arrow" class="w-4 h-4" />
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaStrip />
</Layout>

<style>
  .news {
    background: var(--color-navy);
    padding: 3.5rem 0 4rem;
  }
  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .news-card {
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(35, 35, 64, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out-brand), border-color 0.35s,
      box-shadow 0.35s;
  }
  .news-card:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 91, 189, 0.4);
    box-shadow: 0 24px 48px -22px rgba(0, 0, 0, 0.6);
  }
  .news-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #232340, #101020);
    overflow: hidden;
  }
  .news-thumb-ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: rgba(168, 128, 209, 0.35);
  }
  .news-cat {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(107, 63, 160, 0.85);
    backdrop-filter: blur(4px);
  }
  .news-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
  }
  .news-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .news-dot {
    color: var(--color-purple-300);
  }
  .news-title {
    font-size: 1.1rem;
    line-height: 1.35;
    color: #fff;
    flex: 1;
  }
  .news-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-purple-300);
  }
  .news-more :global(svg) {
    transition: transform 0.3s var(--ease-out-brand);
  }
  .news-card:hover .news-more :global(svg) {
    transform: translateX(4px);
  }
  @media (min-width: 768px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
