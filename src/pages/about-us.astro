---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Partners from '../components/Partners.astro';
import ServicesRail from '../components/ServicesRail.astro';
import RecoveryCta from '../components/RecoveryCta.astro';
import Aurora from '../components/Aurora.astro';
import CtaStrip from '../components/CtaStrip.astro';
import Icon from '../components/Icon.astro';
import { link } from '../lib/paths';

const points = [
  'Certified experts in crypto & blockchain forensics',
  'Global reach - we work with you from anywhere',
  'Free case review with a 48-hour response',
];
---

<Layout
  title="About Us - Cyberclaims"
  description="Discover who we are and how we help recover your lost funds and cryptocurrency with certified crypto & blockchain forensics."
>
  <PageHero
    eyebrow="Turning the impossible into reality"
    title="Discover who we are and how we help recover your lost funds"
    image="/funds-flow.webp"
    imageAlt="Blockchain funds-flow trace"
    fixedHeight
  />

  <section class="ab-body has-aurora">
    <Aurora />
    <div class="wrap">
      <div class="ab-split" data-reveal>
        <div class="ab-section">
          <h2 class="ab-h">
            Turning the Impossible into Reality: Recovering Lost Funds and
            <span class="accent">Cryptocurrency</span>
          </h2>
          <p class="ab-p">
            At Cyberclaims, we specialize in cutting-edge cryptocurrency intelligence and blockchain
            analytics to protect your digital assets and recover lost funds. Whether you’re dealing
            with crypto scams, fraud, or security threats, our expert solutions provide clarity and
            support at every step. Trust us to navigate the complexities of cryptocurrency recovery,
            empowering you to regain control of your financial future with confidence.
          </p>
        </div>
        <div class="ab-visual">
          <img
            class="ab-img"
            src={link('/turning-impossible.webp')}
            alt="A fractured ring reassembling, symbolising recovered assets"
            width="1100"
            height="871"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="ab-rec">
    <RecoveryCta />
  </div>

  <section class="ab-body">
    <div class="wrap ab-inner">
      <div class="ab-section" data-reveal>
        <h2 class="ab-h">Hello, we are <span class="accent">Cyberclaims</span></h2>
        <p class="ab-p">
          We specialize in advanced cryptocurrency tracing to help victims of cyber fraud recover
          lost digital assets. Our certified experts use cutting-edge blockchain analytics to track
          the movement of stolen funds and identify the perpetrators behind crypto theft.
        </p>
        <p class="ab-p">
          Whether your assets were transferred to untraceable wallets or moved across multiple
          platforms, our team is equipped to follow the trail and assist you in navigating the
          complexities of crypto recovery. With a global reach, our services are accessible from
          anywhere in the world, providing you with the support you need to recover your funds
          securely and efficiently.
        </p>
        <p class="ab-p">
          Trust Cyberclaims to be your guide through the blockchain, ensuring you take the right
          steps toward asset recovery.
        </p>
        <ul class="ab-points">
          {
            points.map((p) => (
              <li>
                <span class="ab-check"><Icon name="check" class="w-4 h-4" /></span>
                {p}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <ServicesRail lead="Explore our" accent="services" />

  <section class="ab-body">
    <div class="wrap">
      <div class="ab-split is-reversed" data-reveal>
        <div class="ab-visual">
          <img
            class="ab-img"
            src={link('/values.webp')}
            alt="Interlocking orbits around a glowing core, symbolising our values"
            width="1100"
            height="1008"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="ab-section">
          <h2 class="ab-h">Our <span class="accent">values</span></h2>
          <p class="ab-p">
            At Cyberclaims, we create an environment that attracts top talent in the crypto and
            blockchain recovery industry. Our team uses advanced blockchain analytics to help
            victims of cyber fraud recover stolen digital assets. With a global presence and
            expertise in crypto tracing, we deliver effective, results-driven solutions to clients
            worldwide. Join us and make an impact in the fight against crypto crime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Partners />
  <CtaStrip />
</Layout>

<style>
  .ab-body {
    background: var(--color-navy);
    padding: 3.5rem 0;
  }
  /* hosts the <Aurora /> glow behind this section's content */
  .ab-body.has-aurora {
    position: relative;
    overflow: hidden;
  }
  /* the aurora is taller than this section, so `overflow:hidden` cuts it while
     it is still lit - fade the last stretch back to navy to hide that seam */
  .ab-body.has-aurora::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 12rem;
    background: linear-gradient(to bottom, transparent, var(--color-navy));
    pointer-events: none;
    z-index: 0;
  }
  .has-aurora > .wrap {
    position: relative;
    z-index: 1;
  }
  /* RecoveryCta is transparent by design (it inherits the homepage's shared
     gradient block), so give it the same navy surface as the sections around it */
  .ab-rec {
    background: var(--color-navy);
  }
  .ab-inner {
    max-width: 52rem;
  }
  .ab-section {
    margin-bottom: 2.5rem;
  }
  .ab-section:last-child {
    margin-bottom: 0;
  }

  /* text + artwork side by side */
  .ab-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  .ab-split .ab-section {
    margin-bottom: 0;
    min-width: 0;
  }
  .ab-img {
    display: block;
    width: 100%;
    max-width: 26rem;
    height: auto;
    margin-inline: auto;
  }
  @media (min-width: 900px) {
    .ab-split {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3.5rem;
    }
    /* artwork first in the source order, so it sits left without `order` tricks */
    .ab-split.is-reversed {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }
  .ab-h {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    color: #fff;
    margin: 0 0 1.1rem;
  }
  .ab-p {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .ab-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }
  .ab-points li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.98rem;
  }
  .ab-check {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: rgba(139, 91, 189, 0.15);
    color: var(--color-purple-300);
  }
</style>
