---
import Layout from '../../layouts/Layout.astro';
import Aurora from '../../components/Aurora.astro';
import Sustainability from '../../components/Sustainability.astro';
import RecoveryCta from '../../components/RecoveryCta.astro';
import Icon from '../../components/Icon.astro';
import { localePaths, type Locale } from '../../i18n/config';

// One file, one page per locale. The default locale maps to lang: undefined, and a
// rest parameter matches zero segments — so English stays at /about-us/, not /en/about-us/.
export const getStaticPaths = localePaths;
const { locale } = Astro.props as { locale: Locale };
---

<Layout
  title="URL Checker - Cyberclaims"
  description="Check whether a website URL is flagged as unsafe. Our URL scam checker protects you from phishing, malware and malicious sites."
>
  <section class="uc">
    <Aurora />

    <div class="wrap uc-inner">
      <div class="glass uc-card" data-reveal>
        <h1 class="uc-title">
          <span class="uc-title-ic"><Icon name="forensics" class="w-6 h-6" /></span>
          URL Scam Checker
        </h1>
        <p class="uc-lead">
          Enter a website URL below to check if it’s flagged as unsafe. This tool protects you
          from phishing, malware, and malicious sites that could harm your device or steal your
          data.
        </p>

        <form class="uc-form">
          <input
            class="uc-input"
            type="url"
            name="url"
            aria-label="Website URL"
            placeholder="e.g., https://example.com"
            autocomplete="url"
            spellcheck="false"
          />
          <button type="button" class="btn uc-submit">Check URL</button>
        </form>

        <p class="uc-legal">
          Results are indicative only. For a full investigation, start a case with our team.
        </p>
      </div>
    </div>
  </section>

  <Sustainability />

  <div class="uc-rec">
    <RecoveryCta />
  </div>
</Layout>

<style>
  .uc {
    position: relative;
    overflow: hidden;
    background: var(--color-navy);
    padding: 9.5rem 0 4rem;
  }
  /* the aurora is taller than this section, so `overflow:hidden` cuts it while
     it is still lit - fade the last stretch back to navy to hide that seam */
  .uc::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 12rem;
    background: linear-gradient(to bottom, transparent, var(--color-navy));
    pointer-events: none;
    z-index: 0;
  }
  .uc-inner {
    position: relative;
    z-index: 1;
  }
  .uc-card {
    max-width: 44rem;
    margin-inline: auto;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
  }
  .uc-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: #fff;
    margin: 0 0 1rem;
  }
  .uc-title-ic {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    flex-shrink: 0;
    border-radius: 0.7rem;
    color: #fff;
    background: var(--color-purple-500);
  }
  .uc-lead {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 46ch;
    margin: 0 auto 2rem;
  }
  .uc-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }
  .uc-input {
    width: 100%;
    max-width: 32rem;
    padding: 1rem 1.1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.7rem;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.98rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .uc-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .uc-input:focus {
    outline: none;
    border-color: var(--color-purple-400);
    background: rgba(139, 91, 189, 0.08);
  }
  .uc-submit {
    min-width: 11rem;
    justify-content: center;
  }
  .uc-legal {
    margin: 1.6rem 0 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.4);
  }
  /* RecoveryCta is transparent by design (it inherits the homepage's shared
     gradient block), so give it a surface of its own here */
  .uc-rec {
    background: var(--color-navy);
    padding-top: 2.5rem;
  }
  @media (max-width: 640px) {
    .uc {
      padding-top: 8rem;
    }
    .uc-card {
      padding: 2rem 1.25rem 1.6rem;
    }
    .uc-submit {
      width: 100%;
    }
  }
</style>
