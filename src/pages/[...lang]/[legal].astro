---
// The four legal pages, from src/content/legal/<locale>/<page>.md.
//
// They were four separate .astro files with the text inlined in JSX — the Data
// Protection Addendum alone was 868 lines of markup wrapped around the copy. That is
// unmaintainable for a developer, untouchable for a lawyer, and impossible to
// translate without duplicating the whole file. One route, one Markdown file per
// page per language.
//
// The copy was extracted verbatim and compared character-by-character against the
// original markup before the .astro files were deleted. It is a regulated document:
// do not "improve" it.
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Aurora from '../../components/Aurora.astro';
import CtaStrip from '../../components/CtaStrip.astro';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../i18n/config';
import { formatDate } from '../../i18n';

// Astro evaluates getStaticPaths in isolation, so it cannot see helpers declared
// elsewhere in this frontmatter — everything it needs is either imported or inline.
export async function getStaticPaths() {
  const docs = await getCollection('legal');

  return docs.map((doc) => {
    // Ids look like 'en/privacy-policy.md'. The glob loader keeps the extension, and
    // leaving it in produces /privacy-policy.md/ as the page's URL.
    const [localeSegment, file] = doc.id.split('/');
    const locale = ((LOCALES as readonly string[]).includes(localeSegment)
      ? localeSegment
      : DEFAULT_LOCALE) as Locale;
    const slug = file.replace(/\.mdx?$/, '');

    return {
      params: {
        lang: locale === DEFAULT_LOCALE ? undefined : locale,
        legal: slug,
      },
      props: { doc, locale, slug },
    };
  });
}

const { doc, locale, slug } = Astro.props;
const { Content } = await render(doc);
---

<Layout
  title={`${doc.data.title} - Cyberclaims`}
  description={doc.data.description}
  path={`/${slug}/`}
  locale={locale}
>
  <section class="legal">
    <Aurora />
    <div class="wrap legal-inner">
      <h1 class="h-display legal-title" data-reveal>{doc.data.title}</h1>
      {
        doc.data.updated && (
          <p class="legal-updated" data-reveal>
            Effective as of <time datetime={doc.data.updated.toISOString().slice(0, 10)}>
              {formatDate(doc.data.updated, locale)}
            </time>
          </p>
        )
      }
      <div class="legal-prose" data-reveal>
        <Content />
      </div>
    </div>
  </section>

  <CtaStrip />
</Layout>

<style>
  .legal {
    position: relative;
    overflow: hidden;
    background: var(--color-navy);
    padding: 8rem 0 4rem;
  }
  .legal-inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
  }
  .legal-title {
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
  }
  .legal-updated {
    margin: 0.9rem 0 2.5rem;
    color: var(--color-purple-300);
    font-size: 0.88rem;
  }

  .legal-prose {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.8;
    font-size: 0.97rem;
  }
  .legal-prose :global(> * + *) {
    margin-top: 1.15rem;
  }
  .legal-prose :global(h2) {
    margin-top: 2.75rem;
    font-size: 1.4rem;
    color: #fff;
  }
  .legal-prose :global(h3) {
    margin-top: 2rem;
    font-size: 1.1rem;
    color: #fff;
  }
  .legal-prose :global(strong) {
    color: #fff;
    font-weight: 600;
  }
  .legal-prose :global(a) {
    color: var(--color-purple-300);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* Tailwind's preflight resets `ol, ul { list-style: none }` site-wide, so setting only
     the padding left every list here unmarked and unindented — in a regulated document
     whose numbered clauses are load-bearing. Say what the list is. */
  .legal-prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
  }
  .legal-prose :global(ol) {
    list-style: decimal;
    padding-left: 1.6rem;
  }
  .legal-prose :global(ul ul) {
    list-style: circle;
  }
  .legal-prose :global(ol ol) {
    list-style: lower-alpha;
  }
  .legal-prose :global(li) {
    display: list-item;
    margin-top: 0.5rem;
    padding-left: 0.35rem;
  }
  .legal-prose :global(li > ul),
  .legal-prose :global(li > ol) {
    margin-top: 0.5rem;
  }
  .legal-prose :global(li::marker) {
    color: var(--color-purple-400);
  }
  .legal-prose :global(hr) {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid var(--color-line);
  }
  /* A wide table must scroll inside itself, not push the page sideways. */
  .legal-prose :global(table) {
    display: block;
    overflow-x: auto;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .legal-prose :global(th),
  .legal-prose :global(td) {
    padding: 0.6rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    text-align: left;
    vertical-align: top;
  }
  .legal-prose :global(th) {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    white-space: nowrap;
  }
</style>
