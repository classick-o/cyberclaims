---
import PhoneCheckPage from '../../components/PhoneCheckPage.astro';
import { DEFAULT_LOCALE, type Locale } from '../../i18n/config';
import { PHONE_CHECK, PHONE_CHECK_LOCALES, type PhoneCheckLocale } from '../../data/phone-check-content';

// One page per ScamInfo-supported locale. The default locale maps to lang: undefined so
// English lives at /phone-check/, not /en/phone-check/.
export function getStaticPaths() {
  return PHONE_CHECK_LOCALES.map((locale) => ({
    params: { lang: locale === DEFAULT_LOCALE ? undefined : locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: PhoneCheckLocale };

// hreflang / language-switcher map: the phone-check locales, each at /phone-check/.
const localeSlugs = Object.fromEntries(
  PHONE_CHECK_LOCALES.map((l) => [l, 'phone-check'])
) as Partial<Record<Locale, string>>;

// Default the country dropdown to the one matching the page's locale.
const DEFAULT_ISO: Record<PhoneCheckLocale, string> = {
  en: 'GB',
  nl: 'NL',
  de: 'DE',
  it: 'IT',
  es: 'ES',
  pt: 'PT',
  fr: 'FR',
};
---

<PhoneCheckPage
  c={PHONE_CHECK[locale]}
  locale={locale as Locale}
  reportLocale={locale}
  defaultIso={DEFAULT_ISO[locale]}
  path="/phone-check/"
  localeSlugs={localeSlugs}
  noindex
/>
