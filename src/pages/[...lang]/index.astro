---
import Homepage from '../../components/Homepage.astro';
import { localePaths, type Locale } from '../../i18n/config';

// One file, one page per locale. The default locale maps to lang: undefined, and a
// rest parameter matches zero segments - so English stays at / and the others at /nl/ etc.
// Prerendered: the marketing homepage is HTML on disk and never touches the database.
export const getStaticPaths = localePaths;
const { locale } = Astro.props as { locale: Locale };
---

<Homepage locale={locale} />
