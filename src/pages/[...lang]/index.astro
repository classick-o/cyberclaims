---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import RecoveryCta from '../../components/RecoveryCta.astro';
import Services from '../../components/Services.astro';
import Tracing from '../../components/Tracing.astro';
import WaveLines from '../../components/WaveLines.astro';
import Sustainability from '../../components/Sustainability.astro';
import Testimonials from '../../components/Testimonials.astro';
import Blogs from '../../components/Blogs.astro';
import Partners from '../../components/Partners.astro';
import Press from '../../components/Press.astro';
import CtaStrip from '../../components/CtaStrip.astro';
import { localePaths, type Locale } from '../../i18n/config';

// One file, one page per locale. The default locale maps to lang: undefined, and a
// rest parameter matches zero segments — so English stays at /about-us/, not /en/about-us/.
export const getStaticPaths = localePaths;
const { locale } = Astro.props as { locale: Locale };
---

<style>
  /* One continuous gradient behind About + Recovery so they read as a single surface */
  .about-block {
    background: var(--gradient-depth);
  }
  /* Services + Tracing share one surface + one continuous wave field */
  .invest-block {
    position: relative;
    background: var(--color-navy);
    overflow: hidden;
  }
  .invest-block > :global(section) {
    position: relative;
    z-index: 1;
    background: transparent;
  }
</style>

<Layout notice={false}>
  <Hero />
  <div class="about-block">
    <About />
    <RecoveryCta />
  </div>
  <div class="invest-block">
    <WaveLines />
    <Services />
    <Tracing />
  </div>
  <Sustainability />
  <Testimonials />
  <Blogs server:defer />
  <Partners />
  <Press />
  <CtaStrip />
</Layout>

<script>
  // (scroll-reveal lives site-wide in Layout.astro; the number counters travel
  // with the Sustainability component that renders them)
</script>
