---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import Aurora from '../../components/Aurora.astro';
import CtaStrip from '../../components/CtaStrip.astro';
import Icon from '../../components/Icon.astro';
import Turnstile from '../../components/Turnstile.astro';
import { CONTACT } from '../../data/site';
import { asset } from '../../lib/paths';
import { localePaths, type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n';

// One file, one page per locale. The default locale maps to lang: undefined, and a
// rest parameter matches zero segments - so English stays at /about-us/, not /en/about-us/.
export const getStaticPaths = localePaths;
const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

const flagOf = (region: string): string => (region === 'UK' ? 'GB' : region);
---

<Layout title={t('contact.metaTitle')} description={t('contact.metaDesc')}>
  <PageHero
    eyebrow="Get in touch"
    title={t('nav.contact')}
    intro={[t('contact.heroIntro')]}
    image="/contact-hero.webp"
    imageAlt={t('contact.heroImageAlt')}
    imageWidth={1100}
    imageHeight={1070}
    imageMaxWidth="19rem"
    imageMaxWidthMobile="16rem"
    ctaHref="/start-process/"
    ctaLabel={t('cta.startProcess')}
  />

  <!-- Contact details (left) + office map (right) -->
  <section class="contact">
    <Aurora />
    <div class="wrap contact-grid">
      <div class="contact-info" data-reveal>
        <div class="ci-block">
          <span class="ci-icon"><Icon name="phone" class="w-5 h-5" /></span>
          <div>
            <h3 class="ci-h">{t('contact.callUs')}</h3>
            <ul class="ci-phones">
              {
                CONTACT.phones.map((p) => (
                  <li>
                    <img
                      class="ci-flag"
                      src={asset(`/flags/${flagOf(p.region)}.svg`)}
                      alt={p.region}
                      width="20"
                      height="20"
                      loading="lazy"
                    />
                    <a href={`tel:${p.number.replace(/\s/g, '')}`}>{p.number}</a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="ci-block">
          <span class="ci-icon"><Icon name="mail" class="w-5 h-5" /></span>
          <div>
            <h3 class="ci-h">{t('form.email')}</h3>
            <a class="ci-link" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
          </div>
        </div>

        <div class="ci-block">
          <span class="ci-icon"><Icon name="pin" class="w-5 h-5" /></span>
          <div>
            <h3 class="ci-h">{t('contact.office')}</h3>
            <p class="ci-addr">{t('contact.address')}</p>
          </div>
        </div>
      </div>

      <div class="ci-map" data-reveal>
        <iframe
          title={CONTACT.address}
          aria-label={CONTACT.address}
          src="https://maps.google.com/maps?q=Kalvermarkt%2053%2C%202511%20CB%20Den%20Haag%2C%20Netherlands&t=m&z=14&output=embed&iwloc=near"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Lead form, its own full-width section below -->
  <section class="contact-form-section">
    <div class="wrap">
      <div class="contact-form-wrap" data-reveal>
        <div class="glass contact-form">
          <div id="contactFormHead">
            <h2 class="cf-title">{t('contact.formTitle')}</h2>
            <p class="cf-note">{t('cta.freeReview')}</p>
          </div>
          <form class="lead-form" id="contactForm" method="post" action="/api/lead" novalidate>
            <div class="field">
              <input type="text" name="full_name" required placeholder=" " />
              <label>{t('form.fullName')}</label>
            </div>
            <div class="field-row">
              <div class="field">
                <input type="email" name="email" required placeholder=" " />
                <label>{t('form.email')}</label>
              </div>
              <div class="field">
                <input type="tel" name="phone" required placeholder=" " />
                <label>{t('form.phone')}</label>
              </div>
            </div>
            <div class="field">
              <input type="text" name="country" required placeholder=" " />
              <label>{t('form.country')}</label>
            </div>
            <div class="field">
              <textarea name="message" rows="4" required placeholder=" "></textarea>
              <label>{t('form.message')}</label>
            </div>
            <input
              class="hp"
              type="text"
              name="_honey"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <Turnstile />
            <p class="form-status" data-form-status role="alert" hidden></p>
            <button type="submit" class="btn cf-submit">{t('cta.startProcess')}</button>
            <p class="cf-legal">{t('form.legal')}</p>
          </form>

          <div class="cf-success" id="contactSuccess" hidden>
            <span class="cf-success-icon"><Icon name="check" class="w-full h-full" /></span>
            <h2 class="cf-title">{t('form.successTitle')}</h2>
            <p class="cf-success-p">{t('form.successBody')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaStrip />
</Layout>

<style>
  .contact {
    position: relative;
    overflow: hidden;
    background: var(--color-navy);
    padding: 3.5rem 0 2.5rem;
  }
  /* the aurora is taller than this section, so `overflow:hidden` cuts it while
     it is still lit - fade the last stretch back to navy to hide that seam */
  .contact::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 12rem;
    background: linear-gradient(to bottom, transparent, var(--color-navy));
    pointer-events: none;
    z-index: 0;
  }
  /* keep the details + map above the <Aurora /> glow */
  .contact > .wrap {
    position: relative;
    z-index: 1;
  }
  .contact-form-section {
    background: var(--color-navy);
    padding: 0 0 4rem;
  }
  /* Full width - .wrap's 80rem container is the only limit. */
  .contact-form-wrap {
    max-width: none;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  /* info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .ci-block {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .ci-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.7rem;
    color: #fff;
    background: var(--color-purple-500);
  }
  .ci-h {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-purple-300);
    margin: 0.2rem 0 0.55rem;
  }
  .ci-phones {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ci-phones li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .ci-flag {
    width: 1.3rem;
    height: 1.3rem;
    flex-shrink: 0;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.14);
  }
  .ci-phones a,
  .ci-link {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
  }
  .ci-phones a:hover,
  .ci-link:hover {
    color: #fff;
  }
  .ci-link {
    font-weight: 500;
  }
  .ci-addr {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.55;
    max-width: 18rem;
  }
  .ci-map {
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(139, 91, 189, 0.25);
    /* keep the map legible against the dark theme */
    background: rgba(139, 91, 189, 0.06);
  }
  .ci-map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    filter: grayscale(0.3) invert(0.92) hue-rotate(180deg);
  }

  /* form */
  .contact-form {
    padding: 1.9rem;
  }
  .cf-title {
    font-size: 1.4rem;
  }
  .cf-note {
    margin: 0.35rem 0 1.4rem;
    font-size: 0.85rem;
    color: var(--color-purple-300);
  }
  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    min-width: 0;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
    min-width: 0;
  }
  .field {
    position: relative;
    min-width: 0;
  }
  .field input,
  .field textarea {
    width: 100%;
    min-width: 0;
    padding: 0.95rem 0.9rem 0.35rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.7rem;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    transition: border-color 0.2s, background 0.2s;
    resize: none;
  }
  .field textarea {
    padding-top: 1.3rem;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-purple-400);
    background: rgba(139, 91, 189, 0.08);
  }
  .field label {
    position: absolute;
    left: 0.9rem;
    top: 0.85rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.45);
    pointer-events: none;
    transition: all 0.18s var(--ease-out-brand);
  }
  .field input:focus + label,
  .field input:not(:placeholder-shown) + label,
  .field textarea:focus + label,
  .field textarea:not(:placeholder-shown) + label {
    top: 0.32rem;
    font-size: 0.68rem;
    color: var(--color-purple-300);
  }
  .cf-submit {
    width: 100%;
    margin-top: 0.3rem;
  }
  .cf-legal {
    font-size: 0.72rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
  }

  /* Replaces the form in place after a successful submit. */
  .cf-success {
    text-align: center;
    padding: 1.5rem 0.5rem 1rem;
  }
  .cf-success-icon {
    display: grid;
    place-items: center;
    width: 3.25rem;
    height: 3.25rem;
    margin: 0 auto 1.1rem;
    padding: 0.8rem;
    border-radius: 50%;
    color: #fff;
    background: var(--color-purple-500);
    box-shadow: var(--glow-purple);
  }
  .cf-success-p {
    margin-top: 0.7rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
    max-width: 40ch;
    margin-inline: auto;
  }

  @media (max-width: 520px) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 3.5rem;
      /* let the map match the height of the details column beside it */
      align-items: stretch;
    }
    .ci-map {
      aspect-ratio: auto;
      min-height: 24rem;
    }
  }
</style>

<script>
  import { initLeadForm } from '../../lib/lead-form';

  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const head = document.getElementById('contactFormHead');
  const success = document.getElementById('contactSuccess');

  if (form && head && success) {
    initLeadForm(form, 'contact', () => {
      form.hidden = true;
      head.hidden = true;
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
