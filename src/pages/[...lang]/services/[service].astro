  /* text sits below the fixed artwork zone and shows in full (static) */
  .bento-ic-body {
    position: relative;
    z-index: 2;
    flex: 1;
    padding: 13.5rem 1.4rem 1.6rem;
    /* fixed-length veil: transparent over the whole artwork zone, solid only
       under the text - so it never grows with the card height */
    background: linear-gradient(
      to bottom,
      transparent 0,
      transparent calc(10.5rem - 6px),
      #12101f 13rem
    );
  }
  .bento-ic-term {
    font-size: 1.15rem;
    color: #fff;
    margin: 0 0 0.5rem;
  }
