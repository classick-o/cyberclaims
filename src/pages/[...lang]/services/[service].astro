---
// Individual service page - lives at /services/<slug>/
import Layout from '../../../layouts/Layout.astro';
import PageHero from '../../../components/PageHero.astro';
import Aurora from '../../../components/Aurora.astro';
import CtaStrip from '../../../components/CtaStrip.astro';
import Icon from '../../../components/Icon.astro';
import ServicesRail from '../../../components/ServicesRail.astro';
import { SERVICE_CONTENT, SERVICE_IMAGE, type ServiceBlock } from '../../../data/services-content';
import { asset, absoluteUrl } from '../../../lib/paths';
import { jsonLdScript } from '../../../lib/jsonld';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/config';
import { useTranslations, getServices } from '../../../i18n';

// Two dynamic segments, so this is the cartesian product: every service in every
// locale. With one locale that is exactly the ten pages we had before.
export function getStaticPaths() {
  // getServices(locale) yields the services with their name/blurb already localised, so
  // the page's title, hero and SEO come out translated with no further lookup.
  return LOCALES.flatMap((locale) =>
    getServices(locale).map((s) => ({
      params: {
        lang: locale === DEFAULT_LOCALE ? undefined : locale,
        service: s.href.replace(/^\/|\/$/g, ''),
      },
      props: { service: s, locale },
    }))
  );
}

const { service, locale } = Astro.props as {
  service: ReturnType<typeof getServices>[number];
  locale: Locale;
};
const t = useTranslations(locale);
// The page body for this locale, falling back to English until a translation exists.
const content = (SERVICE_CONTENT[locale] ?? SERVICE_CONTENT.en)[service.href];
const image = SERVICE_IMAGE[service.href];
const intro = content?.intro ?? [service.blurb];

// Due-diligence keeps its bespoke layout, but reads its (translated) copy from `content`
// rather than hardcoding English - so it renders in every locale. Its sections are a
// fixed sequence, addressed here by order; the small accessors narrow the block union.
const ddSec = content?.sections ?? [];
const pText = (b?: ServiceBlock) => (b?.type === 'p' ? b.text : '');
const listItems = (b?: ServiceBlock) => (b?.type === 'list' ? b.items : []);
const defItems = (b?: ServiceBlock) => (b?.type === 'defs' ? b.items : []);
// The two perspective tags are page-only labels, so they live here rather than in the
// shared dictionary that every other page loads.
const DD_TAGS: Record<string, [string, string]> = {
  en: ['For sellers', 'For buyers'],
  nl: ['Voor verkopers', 'Voor kopers'],
  fr: ['Pour les vendeurs', 'Pour les acheteurs'],
  de: ['Für Verkäufer', 'Für Käufer'],
  it: ['Per i venditori', 'Per gli acquirenti'],
};
const [ddSeller, ddBuyer] = DD_TAGS[locale] ?? DD_TAGS.en;

// A palette of visually distinct icons so each card in a "cards" section gets a
// different glyph (cycled by index).
const CARD_ICONS = [
  'shield',
  'lock',
  'alert',
  'globe',
  'forensics',
  'tracing',
  'social',
  'press',
  'clock',
  'business',
];

// 3D glossy artwork for the recurring "techniques" bento cards.
//
// Keyed on a STABLE id, not on the displayed term.
//
// This map used to be keyed on the English term itself ('Cluster Analysis': ...).
// That works right up until someone translates the term - at which point the lookup
// silently misses, every bento card loses its artwork, and nothing errors. It is the
// same class of bug as keying a category on its display name, and it was sitting in
// the one file a translator would touch first. Each `defs` item now carries an `id`
// (see src/data/services-content.ts) and that id is what we look up.
const BENTO_IMG: Record<string, string> = {
  'cluster-analysis': '/bento/cluster-analysis.webp',
  'attribution-data': '/bento/attribution-data.webp',
  'kyc-information': '/bento/kyc-information.webp',
  subpoena: '/bento/subpoena.webp',
  'network-forensics': '/bento/network-forensics.webp',
  'crypto-forensics': '/bento/crypto-forensics.webp',
  'fraudulent-pattern': '/bento/fraudulent-pattern.webp',
  'email-forensics': '/bento/email-forensics.webp',
  'mobile-forensics': '/bento/mobile-forensics.webp',
};

// Service + breadcrumb structured data. Absolute URLs come from Astro.site, so each
// domain self-references correctly.
const svcUrl = absoluteUrl(`/services${service.href}`, locale, Astro.site);
const svcOrigin = (Astro.site?.origin ?? 'https://www.cyberclaims.net').replace(/\/$/, '');
const serviceLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${svcUrl}#service`,
      name: service.title,
      description: service.blurb,
      serviceType: service.title,
      provider: { '@type': 'Organization', name: 'CyberClaims', url: `${svcOrigin}/` },
      areaServed: 'Worldwide',
      url: svcUrl,
      inLanguage: locale,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/', locale, Astro.site) },
        { '@type': 'ListItem', position: 2, name: t('nav.services'), item: absoluteUrl('/services/', locale, Astro.site) },
        { '@type': 'ListItem', position: 3, name: service.title, item: svcUrl },
      ],
    },
  ],
};
---

<Layout title={`${service.title} - Cyberclaims`} description={service.blurb}>
  <script type="application/ld+json" slot="head" set:html={jsonLdScript(serviceLd)} />
  <PageHero
    eyebrow={content?.eyebrow ?? 'Our Services'}
    title={service.title}
    intro={intro}
    image={image}
    imageAlt={service.title}
    fixedHeight
    fullHeightMobile
    scrollHint
  />

  {
    service.href === '/due-diligence-investigations/' && content ? (
      <section class="svc-body dd">
        <Aurora />
        <div class="wrap dd-inner">
          <div class="dd-sec">
            <h2 class="dd-h">{ddSec[0]?.heading}</h2>
            <p class="dd-lead">{pText(ddSec[0]?.blocks[0])}</p>
            <div class="dd-areas">
              {listItems(ddSec[0]?.blocks[1]).map((a) => (
                <span class="dd-area">
                  <span class="dd-area-ic">
                    <Icon name="check" class="w-4 h-4" />
                  </span>
                  {a}
                </span>
              ))}
            </div>
          </div>

          <div class="dd-sec">
            <h2 class="dd-h">{ddSec[1]?.heading}</h2>
            <p class="dd-lead">{pText(ddSec[1]?.blocks[0])}</p>
            <div class="svc-bento img count-3">
              {defItems(ddSec[1]?.blocks[1]).map((d) => (
                <article class="bento-ic">
                  <span class="bento-ic-glow" aria-hidden="true" />
                  {d.id && BENTO_IMG[d.id] && (
                    <img
                      class="bento-ic-img"
                      src={asset(BENTO_IMG[d.id])}
                      alt=""
                      aria-hidden="true"
                      loading="lazy"
                    />
                  )}
                  <div class="bento-ic-body">
                    <h3 class="bento-ic-term">{d.term}</h3>
                    <p class="bento-ic-desc">{d.text}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <div class="dd-sec">
            <h2 class="dd-h">{ddSec[2]?.heading}</h2>
            <div class="dd-grid6">
              {defItems(ddSec[2]?.blocks[0]).map((it, i) => (
                <div class="dd-num-card">
                  <div class="dd-num-head">
                    <span class="dd-num">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="dd-card-h">{it.term}</h3>
                  </div>
                  <p class="dd-card-p">{it.text}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="dd-sec">
            <h2 class="dd-h">{ddSec[3]?.heading}</h2>
            <div class="dd-split">
              <div class="dd-persp">
                <span class="dd-persp-tag">{ddSeller}</span>
                <p class="dd-card-p">{pText(ddSec[3]?.blocks[0])}</p>
              </div>
              <div class="dd-persp">
                <span class="dd-persp-tag">{ddBuyer}</span>
                <p class="dd-card-p">{pText(ddSec[3]?.blocks[1])}</p>
              </div>
            </div>
          </div>

          <div class="dd-sec">
            <h2 class="dd-h">{ddSec[4]?.heading}</h2>
            <p class="dd-lead">{pText(ddSec[4]?.blocks[0])}</p>
            <ol class="dd-steps">
              {listItems(ddSec[4]?.blocks[1]).map((s, i) => (
                <li class="dd-step">
                  <span class="dd-step-num">{i + 1}</span>
                  <p>{s}</p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    ) : content ? (
      <section class="svc-body">
        <Aurora />
        <div class="wrap svc-body-inner">
          {content.sections.map((sec) => (
            <div class="svc-section" data-reveal>
              {sec.heading && <h2 class="svc-h">{sec.heading}</h2>}
              {sec.blocks.map((b) =>
                b.type === 'p' ? (
                  <p class="svc-p">{b.text}</p>
                ) : b.type === 'list' ? (
                  <ul
                    class={`svc-list ${b.layout === 'stack' ? 'is-stack' : 'is-row'}${b.grid ? ' is-tpl' : ''}`}
                    style={
                      b.grid
                        ? `--svc-grid:${b.grid}`
                        : b.cols
                          ? `--svc-cols:${b.cols}`
                          : undefined
                    }
                  >
                    {b.items.map((it) => (
                      <li class="svc-li">
                        <span class="svc-li-ic">
                          <Icon name="check" class="w-4 h-4" />
                        </span>
                        <span>{it}</span>
                      </li>
                    ))}
                  </ul>
                ) : b.layout === 'cards' ? (
                  (() => {
                    // the longest-text card becomes a tall feature on the right (bento)
                    const tallIdx = b.items.reduce(
                      (m, x, j, a) => (x.text.length > a[m].text.length ? j : m),
                      0
                    );
                    return (
                      <div
                        class={`svc-cards bento n${b.items.length}`}
                        style={[
                          b.grid ? `--svc-card-grid:${b.grid}` : null,
                          b.cols ? `--svc-card-cols:${b.cols}` : null,
                        ]
                          .filter(Boolean)
                          .join(';') || undefined}
                      >
                        {b.items.map((d, i) => (
                          <div class={`svc-card${i === tallIdx ? ' is-tall' : ''}`}>
                            <div class="svc-card-head">
                              <span class="svc-card-ic">
                                <Icon name={CARD_ICONS[i % CARD_ICONS.length]} class="w-5 h-5" />
                              </span>
                              <h3 class="svc-card-term">{d.term}</h3>
                            </div>
                            <p class="svc-card-text">{d.text}</p>
                          </div>
                        ))}
                      </div>
                    );
                  })()
                ) : b.items.every((d) => d.id && BENTO_IMG[d.id]) ? (
                  <div
                    class={`svc-bento img ${b.centerImage ? 'logo6' : `count-${b.items.length}`}`}
                  >
                    {(b.centerImage
                      ? [
                          ...b.items
                            .slice(0, Math.ceil(b.items.length / 2))
                            .map((d) => ({ d, logo: '' })),
                          { d: null, logo: b.centerImage },
                          ...b.items
                            .slice(Math.ceil(b.items.length / 2))
                            .map((d) => ({ d, logo: '' })),
                        ]
                      : b.items.map((d) => ({ d, logo: '' }))
                    ).map((t) =>
                      t.logo ? (
                        <div class="bento-ic is-logo">
                          <span class="bento-ic-glow" aria-hidden="true" />
                          <img
                            class="bento-logo-img"
                            src={asset(t.logo)}
                            alt="Cyberclaims"
                            loading="lazy"
                          />
                        </div>
                      ) : (
                        // t.d is non-null in this branch by construction - the tile is
                        // either the centre logo (t.logo set, t.d null) or a definition
                        // (t.d set, t.logo empty). TypeScript can't see that from the
                        // ternary, hence the assertions.
                        <article class="bento-ic">
                          <span class="bento-ic-glow" aria-hidden="true" />
                          <img
                            class="bento-ic-img"
                            src={asset(BENTO_IMG[t.d!.id!])}
                            alt=""
                            aria-hidden="true"
                            loading="lazy"
                          />
                          <div class="bento-ic-body">
                            <h3 class="bento-ic-term">{t.d!.term}</h3>
                            <p class="bento-ic-desc">{t.d!.text}</p>
                          </div>
                        </article>
                      )
                    )}
                  </div>
                ) : (
                  <div class={`svc-bento bento-${b.items.length}`}>
                    {b.items.map((d) => (
                      <div class="svc-bento-card">
                        <h3 class="svc-bento-term">{d.term}</h3>
                        <p class="svc-bento-text">{d.text}</p>
                      </div>
                    ))}
                  </div>
                )
              )}
            </div>
          ))}
        </div>
      </section>
    ) : null
  }

  <ServicesRail lead={t('servicesRail.exploreOther')} accent={t('servicesRail.services')} exclude={service.href} />

  <CtaStrip />
</Layout>

<style>
  .svc-body {
    position: relative;
    overflow: hidden;
    background: var(--color-navy);
    /* aurora glows from the top; the first heading sits over its brighter part */
    padding: 4.5rem 0 3.5rem;
  }
  /* dithered fade: tiny dots grow denser toward the bottom and dissolve into
     the darker "Explore other services" section below */
  .svc-body::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 22rem;
    background-image:
      radial-gradient(var(--color-navy-deep) 1.2px, transparent 1.6px),
      linear-gradient(to bottom, transparent 20%, var(--color-navy-deep));
    background-size: 5px 5px, 100% 100%;
    background-position: bottom;
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 90%);
    mask-image: linear-gradient(to bottom, transparent, #000 90%);
    pointer-events: none;
    z-index: 0;
  }
  .svc-body-inner {
    position: relative;
    z-index: 1;
    max-width: 66rem;
  }
  @media (max-width: 640px) {
    .svc-body {
      padding-top: 4rem;
    }
  }

  /* ===== bespoke Due Diligence layout ===== */
  .svc-body.dd {
    padding-top: 4.5rem;
  }
  .dd-inner {
    position: relative;
    z-index: 1;
    max-width: 70rem;
  }
  .dd-sec {
    margin-bottom: 3.75rem;
  }
  .dd-sec:last-child {
    margin-bottom: 0;
  }
  .dd-h {
    font-size: clamp(1.5rem, 3vw, 2.15rem);
    line-height: 1.15;
    color: #fff;
    margin: 0 auto 1.1rem;
    max-width: 40ch;
    text-align: center;
  }
  .dd-lead {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.8;
    max-width: none;
    margin: 0 0 1.7rem;
    text-align: center;
  }
  /* areas we cover */
  .dd-areas {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.7rem;
  }
  .dd-area {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.1rem;
    border-radius: 0.75rem;
    /* frosted glass */
    background: rgba(30, 30, 52, 0.4);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    backdrop-filter: blur(12px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.86);
    font-size: 0.95rem;
    transition: border-color 0.3s, transform 0.3s var(--ease-out-brand);
  }
  .dd-area:hover {
    border-color: rgba(139, 91, 189, 0.4);
    transform: translateY(-2px);
  }
  .dd-area-ic {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    color: var(--color-purple-300);
    background: rgba(139, 91, 189, 0.16);
  }
  @media (min-width: 640px) {
    .dd-areas {
      grid-template-columns: 1fr 1fr;
    }
  }
  /* technique cards */
  .dd-tech {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .dd-card {
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(35, 35, 64, 0.4);
    border: 1px solid rgba(139, 91, 189, 0.2);
    transition: border-color 0.3s, transform 0.3s var(--ease-out-brand);
  }
  .dd-card:hover {
    border-color: rgba(139, 91, 189, 0.45);
    transform: translateY(-4px);
  }
  .dd-card-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.9rem;
  }
  .dd-card-ic {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.65rem;
    color: #fff;
    background: var(--color-purple-500);
  }
  .dd-card-h {
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 0.5rem;
  }
  .dd-card-head .dd-card-h {
    margin: 0;
  }
  .dd-card-p {
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.65;
    font-size: 0.95rem;
    margin: 0;
  }
  @media (min-width: 860px) {
    .dd-tech {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  /* numbered 6-grid */
  .dd-grid6 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  .dd-num-card {
    position: relative;
    padding: 0.95rem 1.05rem 1rem;
    border-radius: 0.9rem;
    background: rgba(35, 35, 64, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: border-color 0.3s, transform 0.3s var(--ease-out-brand);
  }
  .dd-num-card:hover {
    border-color: rgba(139, 91, 189, 0.4);
    transform: translateY(-4px);
  }
  .dd-num-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .dd-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--color-purple-400);
    opacity: 0.7;
  }
  .dd-num-head .dd-card-h {
    margin: 0;
    font-size: 1rem;
  }
  .dd-num-card .dd-card-p {
    font-size: 0.86rem;
  }
  @media (min-width: 640px) {
    .dd-grid6 {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 960px) {
    .dd-grid6 {
      grid-template-columns: repeat(3, 1fr);
      row-gap: 2.5rem;
    }
    /* explicit snake placement: row 1 left-to-right, row 2 right-to-left, so
       4 sits directly below 3 and the whole chain stays connected */
    .dd-num-card:nth-child(1) {
      grid-area: 1 / 1;
    }
    .dd-num-card:nth-child(2) {
      grid-area: 1 / 2;
    }
    .dd-num-card:nth-child(3) {
      grid-area: 1 / 3;
    }
    .dd-num-card:nth-child(4) {
      grid-area: 2 / 3;
    }
    .dd-num-card:nth-child(5) {
      grid-area: 2 / 2;
    }
    .dd-num-card:nth-child(6) {
      grid-area: 2 / 1;
    }
    /* base: horizontal dashed connector to the right, vertically centred */
    .dd-num-card::after {
      content: '';
      position: absolute;
      top: 50%;
      right: -1.75rem;
      width: 1.75rem;
      height: 2px;
      transform: translateY(-50%);
      background: repeating-linear-gradient(
        90deg,
        var(--color-purple-400) 0 6px,
        transparent 6px 12px
      );
      background-size: 24px 2px;
      opacity: 0.7;
      animation: dd-dash 0.8s linear infinite;
    }
    /* 3 -> 4 : vertical connector down to the card below */
    .dd-num-card:nth-child(3)::after {
      top: auto;
      bottom: -2.5rem;
      right: 50%;
      width: 2px;
      height: 2.5rem;
      transform: translateX(50%);
      background: repeating-linear-gradient(
        0deg,
        var(--color-purple-400) 0 6px,
        transparent 6px 12px
      );
      background-size: 2px 24px;
      animation: dd-dash-v 0.8s linear infinite;
    }
    /* 4 -> 5 and 5 -> 6 flow leftwards */
    .dd-num-card:nth-child(4)::after,
    .dd-num-card:nth-child(5)::after {
      right: auto;
      left: -1.75rem;
      animation-direction: reverse;
    }
    /* last card: no connector */
    .dd-num-card:nth-child(6)::after {
      display: none;
    }
  }
  @keyframes dd-dash {
    to {
      background-position: 24px 0;
    }
  }
  @keyframes dd-dash-v {
    to {
      background-position: 0 24px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .dd-num-card::after {
      animation: none;
    }
  }
  /* seller / buyer split */
  .dd-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .dd-persp {
    padding: 1.25rem 1.35rem;
    border-radius: 1rem;
    background: linear-gradient(160deg, rgba(139, 91, 189, 0.12), rgba(35, 35, 64, 0.35));
    border: 1px solid rgba(139, 91, 189, 0.22);
  }
  .dd-persp-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-purple-300);
    margin-bottom: 0.7rem;
  }
  @media (min-width: 760px) {
    .dd-split {
      grid-template-columns: 1fr 1fr;
    }
  }
  /* process steps */
  .dd-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .dd-step {
    position: relative;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.5rem 0;
  }
  .dd-step-num {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: #fff;
    background: var(--color-purple-500);
    z-index: 1;
  }
  .dd-step:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 1.1rem;
    top: 2.2rem;
    bottom: -0.5rem;
    width: 2px;
    background: rgba(139, 91, 189, 0.3);
  }
  .dd-step p {
