  }
  @media (min-width: 900px) {
    /* masonry: 2 wide cards on top; below, two tall side cards flank a middle
       column holding the logo (small, centred) above one more card */
    .svc-bento.img.logo6 {
      grid-template-columns: repeat(6, 1fr);
    }
    /* row 1 - two wide cards */
    .svc-bento.img.logo6 .bento-ic:nth-child(1) {
      grid-row: 1;
      grid-column: 1 / 4;
    }
    .svc-bento.img.logo6 .bento-ic:nth-child(2) {
      grid-row: 1;
      grid-column: 4 / 7;
    }
    /* left tall card */
    .svc-bento.img.logo6 .bento-ic:nth-child(3) {
      grid-row: 2 / 4;
      grid-column: 1 / 3;
    }
    /* centred logo tile */
    .svc-bento.img.logo6 .bento-ic:nth-child(4) {
      grid-row: 2;
      grid-column: 3 / 5;
    }
    /* card beneath the logo */
    .svc-bento.img.logo6 .bento-ic:nth-child(5) {
      grid-row: 3;
      grid-column: 3 / 5;
    }
    /* right tall card */
    .svc-bento.img.logo6 .bento-ic:nth-child(6) {
      grid-row: 2 / 4;
      grid-column: 5 / 7;
    }
    /* tall side cards get a larger image so they don't read as half-empty */
    .svc-bento.img.logo6 .bento-ic:nth-child(3) .bento-ic-img,
    .svc-bento.img.logo6 .bento-ic:nth-child(6) .bento-ic-img {
      width: 15.5rem;
      height: 15.5rem;
    }
    /* LEFT tall card: image on top, text pinned to the bottom */
    .svc-bento.img.logo6 .bento-ic:nth-child(3) .bento-ic-img {
      top: 2.5rem;
    }
    .svc-bento.img.logo6 .bento-ic:nth-child(3) .bento-ic-body {
      display: flex;
