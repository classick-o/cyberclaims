</style>

<script>
  // Mobile-only pagination dots for the image bento carousels. Dots are derived
  // from the cards that are actually visible, so the hidden logo tile in the
  // `logo6` bento is skipped without special-casing it here.
  const MOBILE = window.matchMedia('(max-width: 767px)');

  document.querySelectorAll<HTMLElement>('.svc-bento.img').forEach((rail) => {
    const dots = document.createElement('div');
    dots.className = 'bento-dots';
    dots.setAttribute('role', 'tablist');
    dots.setAttribute('aria-label', 'Carousel pagination');
    rail.after(dots);

    const cards = () =>
      (Array.from(rail.children) as HTMLElement[]).filter((c) => c.offsetParent !== null);

    const sync = () => {
      const list = cards();
      const buttons = Array.from(dots.children) as HTMLElement[];
      if (!buttons.length) return;
      const mid = rail.scrollLeft + rail.clientWidth / 2;
      let best = 0;
      let bestDist = Infinity;
      list.forEach((c, i) => {
        const d = Math.abs(c.offsetLeft + c.offsetWidth / 2 - mid);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      buttons.forEach((b, i) => {
        const active = i === best;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });
    };

    const build = () => {
      dots.textContent = '';
      // above the breakpoint the bento is a real grid - no carousel, no dots
      if (!MOBILE.matches) return;
      cards().forEach((_, i) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'bento-dot';
        b.setAttribute('role', 'tab');
        b.setAttribute('aria-label', `Show card ${i + 1}`);
        b.addEventListener('click', () => {
          const c = cards()[i];
          if (!c) return;
          rail.scrollTo({
            left: c.offsetLeft - (rail.clientWidth - c.offsetWidth) / 2,
            behavior: 'smooth',
          });
        });
        dots.appendChild(b);
      });
      sync();
    };

    rail.addEventListener('scroll', sync, { passive: true });
    MOBILE.addEventListener('change', build);
    window.addEventListener('resize', sync);
    build();
  });
</script>
