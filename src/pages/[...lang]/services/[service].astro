    .svc-bento.img.logo6 .bento-ic:nth-child(6) .bento-ic-body {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding: 1.6rem 1.4rem;
      /* same soft fade as the left card, just mirrored top-to-bottom */
