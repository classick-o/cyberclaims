      justify-content: flex-end;
      padding: 1.6rem 1.4rem;
      background: linear-gradient(to top, #12101f 32%, transparent 64%);
    }
    /* RIGHT tall card: inverted - text on top, image at the bottom (mirror of left) */
    /* flip the card's ambient glow to the bottom (opposite of the left card) */
    .svc-bento.img.logo6 .bento-ic:nth-child(6) {
      background:
        radial-gradient(120% 80% at 50% 100%, rgba(107, 63, 160, 0.28), transparent 60%),
