    margin: 0 0 1rem;
    text-align: center;
  }
  /* lists as check pills */
  .svc-list {
    list-style: none;
    display: grid;
    gap: 0.7rem;
    margin: 1.5rem 0;
  }
  /* row lists become N columns (default 3, override via --svc-cols); stacked
     lists are always one full-width item per row */
  .svc-list.is-row {
    grid-template-columns: 1fr;
  }
  .svc-list.is-stack {
    grid-template-columns: 1fr;
  }
  @media (min-width: 560px) {
    .svc-list.is-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 820px) {
    .svc-list.is-row {
      grid-template-columns: repeat(var(--svc-cols, 3), 1fr);
    }
    .svc-list.is-row.is-tpl {
      grid-template-columns: var(--svc-grid);
    }
  }
  .svc-li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 0.9rem;
    border-radius: 0.75rem;
