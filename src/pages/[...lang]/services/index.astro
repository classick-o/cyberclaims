---
// Services index - all services in a card grid (lives at /services/).
import Layout from '../../../layouts/Layout.astro';
import PageHero from '../../../components/PageHero.astro';
import ArcGlow from '../../../components/ArcGlow.astro';
import CtaStrip from '../../../components/CtaStrip.astro';
import Icon from '../../../components/Icon.astro';
import { SERVICES, URL_CHECKER } from '../../../data/site';
import { SERVICE_IMAGE } from '../../../data/services-content';
import { asset, link, serviceUrl } from '../../../lib/paths';
import { localePaths, type Locale } from '../../../i18n/config';

// One file, one page per locale. The default locale maps to lang: undefined, and a
// rest parameter matches zero segments — so English stays at /about-us/, not /en/about-us/.
export const getStaticPaths = localePaths;
const { locale } = Astro.props as { locale: Locale };
---

<Layout
  title="Our Services - Cyberclaims"
  description="From tracing stolen crypto to website takedowns, our certified experts cover the full spectrum of cyber-fraud investigation and asset recovery."
>
  <PageHero
    eyebrow="What we do"
    title="Our Services"
    intro={[
      'From tracing stolen crypto to taking down fraudulent websites, our certified experts cover the full spectrum of cyber-fraud investigation and asset recovery.',
    ]}
    image="/services-hero.webp"
    imageAlt="Floating tiles showing bitcoin, a shield, a magnifier, scales, a document and a blocked site"
    imageMaxWidth="24rem"
    imageMaxWidthMobile="17rem"
  />

  <section class="svcs">
    <ArcGlow />
    <div class="wrap">
      <div class="svcs-grid">
        {
          SERVICES.map((s) => (
            <a href={link(serviceUrl(s.href), locale)} class="svc-card" data-svc={s.href} data-reveal>
              <img
                class="svc-card-visual"
                src={asset(SERVICE_IMAGE[s.href])}
                alt=""
                aria-hidden="true"
                loading="lazy"
              />
              <div class="svc-card-body">
                <h2 class="svc-card-title">{s.title}</h2>
                <p class="svc-card-blurb">{s.blurb}</p>
                <span class="svc-card-more">
                  Explore service <Icon name="arrow" class="w-4 h-4" />
                </span>
              </div>
            </a>
          ))
        }

        {/* the URL Checker is a tool, not a /services/ page - hence the plain href */}
        <a href={link(URL_CHECKER.href, locale)} class="svc-card" data-svc="/url-checker/" data-reveal>
          <img
            class="svc-card-visual"
            src={asset('/sv-url-checker.webp')}
            alt=""
            aria-hidden="true"
            loading="lazy"
          />
          <div class="svc-card-body">
            <h2 class="svc-card-title">{URL_CHECKER.title}</h2>
            <p class="svc-card-blurb">
              Check whether a website is flagged as unsafe before you trust it with your data.
            </p>
            <span class="svc-card-more">
              Open checker <Icon name="arrow" class="w-4 h-4" />
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <CtaStrip />
</Layout>

<style>
  .svcs {
    position: relative;
    overflow: hidden;
    background: var(--color-navy);
    /* the cards are opaque, so the <ArcGlow /> backdrop needs clear space at the
       top of the section to actually read - 3.5rem left it almost fully covered */
    padding: 7rem 0 4rem;
  }
  /* keep the cards above the <ArcGlow /> backdrop */
  .svcs > .wrap {
    position: relative;
    z-index: 1;
  }
  .svcs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  /* Same card design as the <ServicesRail /> panels: the artwork sits on the
     panel and fades into the text, rather than living in a boxed thumbnail. */
  .svc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 25rem;
    padding: 1.6rem 1.2rem 1.9rem;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    background: linear-gradient(180deg, #1b1630, #0f0f1d);
    border: 1px solid color-mix(in srgb, #8b5bbd 25%, transparent);
    transition: transform 0.35s var(--ease-out-brand), border-color 0.35s,
      box-shadow 0.35s;
  }
  .svc-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, #8b5bbd 45%, transparent);
    box-shadow: 0 24px 48px -22px rgba(0, 0, 0, 0.6);
  }
  .svc-card-visual {
    position: absolute;
    top: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 104%;
    max-width: 30rem;
    height: auto;
    z-index: 0;
    pointer-events: none;
  }
  /* the maze (tracing) is bright and reads well a touch larger */
  .svc-card[data-svc='/cryptocurrency-tracing/'] .svc-card-visual {
    width: 118%;
    max-width: 34rem;
  }
  /* a single wide tile - at 104% it overflows the card and gets clipped */
  .svc-card[data-svc='/url-checker/'] .svc-card-visual {
    width: 66%;
    top: 1.8rem;
  }
  /* these three sit low in their frame - lift them up */
  .svc-card[data-svc='/cryptocurrency-recovery/'] .svc-card-visual,
  .svc-card[data-svc='/website-forensics/'] .svc-card-visual,
  .svc-card[data-svc='/website-takedown/'] .svc-card-visual {
    top: -2rem;
  }
  /* softer fade so the darker objects don't dissolve into the panel */
  .svc-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 26%, #141224 64%, #0f0f1d 100%);
  }
  .svc-card-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .svc-card-title {
    font-size: 1.35rem;
    color: #fff;
    margin: 0;
  }
  .svc-card-blurb {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.5;
  }
  /* solid purple button (matches the rail + homepage showcase panels) */
  .svc-card-more {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.5rem;
    margin-top: 0.7rem;
    padding: 0.6rem 1.1rem;
    border-radius: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.82rem;
    color: #fff;
    background: var(--color-purple-500);
    box-shadow: 0 8px 24px -8px rgba(107, 63, 160, 0.7);
    transition: background 0.25s var(--ease-out-brand),
      transform 0.25s var(--ease-out-brand);
  }
  .svc-card:hover .svc-card-more {
    background: var(--color-purple-400);
    transform: translateY(-2px);
  }
  @media (min-width: 640px) {
    .svcs-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .svcs-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }
</style>
