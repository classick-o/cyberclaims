---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { link } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Cyberclaims - Crypto Tracing & Fraud Investigation',
  description = 'Cyberclaims provides expert crypto tracing and investigation services to help victims of crypto fraud trace and freeze their assets.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href={link('/favicon-32.png')} />
    <link rel="icon" type="image/png" sizes="192x192" href={link('/favicon-192.png')} />
    <link rel="apple-touch-icon" href={link('/favicon-192.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
