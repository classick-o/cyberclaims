---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ImpersonatorNotice from '../components/ImpersonatorNotice.astro';
import { asset, absoluteUrl } from '../lib/paths';
import { LOCALES, DEFAULT_LOCALE, LOCALE_META, localeFromUrl, type Locale } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  notice?: boolean; // show the "Beware of Impersonators" band (default true)
  locale?: Locale;
  /** Locale-independent path of this page, e.g. '/about-us/'. Used for canonical + hreflang. */
  path?: string;
  /**
   * For pages whose URL differs per locale (articles - the slug is translated too): a map
   * of locale to that locale's slug. Drives hreflang and the language switcher so they
   * point at the real translated URL rather than a prefix-swapped 404. Omit it and every
   * locale is assumed to share `path`, which is true for every static page.
   */
  localeSlugs?: Partial<Record<Locale, string>>;
  /** Keep this page out of search results (draft previews, the thank-you page). */
  noindex?: boolean;
}
const {
  title = 'Cyberclaims - Crypto Tracing & Fraud Investigation',
  description = 'Cyberclaims provides expert crypto tracing and investigation services to help victims of crypto fraud trace and freeze their assets.',
  notice = true,
  noindex = false,
} = Astro.props;

// Site-wide indexing switch, read at build/SSR time from the environment. Off by
// default (and off on the cyberclaims.nl staging domain), so unless a deployment
// explicitly sets ALLOW_INDEXING=true every page carries noindex. A per-page
// `noindex` prop (drafts, thank-you) still forces it regardless. The X-Robots-Tag
// header in backend/server.js enforces the same thing at runtime as a backstop.
const robotsNoindex = noindex || process.env.ALLOW_INDEXING !== 'true';

// Prerendered pages hand the locale down as a prop. SSR routes (the blog) have no
// getStaticPaths to do that, so they fall back to reading it out of the URL.
const locale: Locale = Astro.props.locale ?? localeFromUrl(Astro.url);
const meta = LOCALE_META[locale];

// The canonical path WITHOUT any locale prefix, so hreflang can rebuild each variant.
// Passed explicitly where it matters; otherwise derived by stripping the prefix.
const path =
  Astro.props.path ??
  (() => {
    const segments = Astro.url.pathname.split('/').filter(Boolean);
    if (segments[0] === locale && locale !== DEFAULT_LOCALE) segments.shift();
    return `/${segments.join('/')}${segments.length ? '/' : ''}`;
  })();

// Language alternates. For a page that shares one path across locales this is just that
// path in each language; an article passes localeSlugs and each alternate points at that
// locale's own slug. The switcher (in the header) is fed the same map.
const localeSlugs = Astro.props.localeSlugs;
const alternates: [Locale, string][] =
  localeSlugs && Object.keys(localeSlugs).length > 0
    ? (Object.entries(localeSlugs) as [Locale, string][]).map(([l, slug]) => [l, `/${slug}/`])
    : LOCALES.map((l) => [l, path]);
const xDefaultPath = localeSlugs?.[DEFAULT_LOCALE] ? `/${localeSlugs[DEFAULT_LOCALE]}/` : path;
---

<!doctype html>
<html lang={meta.htmlLang} data-intl={meta.intl}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {robotsNoindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={absoluteUrl(path, locale, Astro.site)} />

    {/* hreflang. Inert while LOCALES has one entry; correct the moment it doesn't. */}
    {
      LOCALES.length > 1 &&
        alternates.map(([l, p]) => (
          <link rel="alternate" hreflang={LOCALE_META[l].htmlLang} href={absoluteUrl(p, l, Astro.site)} />
        ))
    }
    {
      LOCALES.length > 1 && (
        <link rel="alternate" hreflang="x-default" href={absoluteUrl(xDefaultPath, DEFAULT_LOCALE, Astro.site)} />
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={meta.ogLocale} />
    <meta property="og:url" content={absoluteUrl(path, locale, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" sizes="32x32" href={asset('/favicon-32.png')} />
    <link rel="icon" type="image/png" sizes="192x192" href={asset('/favicon-192.png')} />
    <link rel="apple-touch-icon" href={asset('/favicon-192.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <Header locale={locale} localeSlugs={localeSlugs} />
    <main>
      <slot />
    </main>
    {notice && <ImpersonatorNotice />}
    <Footer locale={locale} />
  </body>
</html>

<script>
  // Site-wide scroll-reveal (fade/slide-up) so [data-reveal] works on every page.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const onIntersect: IntersectionObserverCallback = (entries, observer) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        el.style.transitionDelay = `${Math.min(i * 60, 240)}ms`;
        el.classList.add('is-visible');
        observer.unobserve(el);
      }
    });
  };
  const observe = (threshold: number) =>
    new IntersectionObserver(onIntersect, { threshold, rootMargin: '0px 0px -8% 0px' });

  const normal = observe(0.12);
  // An element taller than the viewport can never show 12% of itself at once,
  // so it would stay at opacity:0 forever. Reveal those on first contact.
  const tall = observe(0);

  const watch = (el: HTMLElement) => {
    if (el.dataset.revealWatched) return;
    el.dataset.revealWatched = '1';
    if (reduce) {
      el.classList.add('is-visible');
      return;
    }
    (el.offsetHeight > window.innerHeight * 0.75 ? tall : normal).observe(el);
  };

  document.querySelectorAll<HTMLElement>('[data-reveal]').forEach(watch);

  // Content that arrives AFTER this script has run must be picked up too.
  //
  // The homepage's article strip is a server island: Astro fetches it and injects it
  // into the page once this script is long done. Everything inside it carries
  // [data-reveal], which starts at opacity: 0 - so it was sitting in the DOM at its
  // full height, permanently invisible, because nothing was ever watching for it.
  // A whole section of the homepage, gone, with a 520px hole where it should have been.
  new MutationObserver((records) => {
    for (const record of records) {
      for (const node of record.addedNodes) {
        if (!(node instanceof HTMLElement)) continue;
        if (node.hasAttribute('data-reveal')) watch(node);
        node.querySelectorAll<HTMLElement>('[data-reveal]').forEach(watch);
      }
    }
  }).observe(document.body, { childList: true, subtree: true });
</script>
