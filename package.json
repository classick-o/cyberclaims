{
  "name": "cyberclaims",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "main": "server.cjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:api": "node --watch backend/server.js",
    "dev:admin": "vite --config admin/vite.config.js",
    "build": "npm run build:site && npm run build:admin",
    "build:site": "astro build",
    "build:admin": "vite build --config admin/vite.config.js",
    "prestart": "node backend/scripts/migrate.js",
    "start": "node backend/server.js",
    "migrate": "node backend/scripts/migrate.js",
    "seed:admin": "node backend/scripts/seed-admin.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^9.0.0",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extensions": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "astro": "^5.6.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^22.0.1",
    "helmet": "^8.0.0",
    "htmlparser2": "^12.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "nodemailer": "^6.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.35.3",
    "three": "^0.185.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.0.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.0.17",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  }
}
